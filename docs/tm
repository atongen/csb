#!/usr/bin/env bash
#
# tm
#
# Wraps tmux for easy workspace switching.
# Searches paths listed in $TMPATH for workspace root directories.
#
# Git-repo workspaces:
#   When the resolved workspace is a git repo and WINDOW_NAME is given (and
#   is not the default "main"), WINDOW_NAME is treated as a branch name:
#     - branch is created from HEAD if it doesn't exist
#     - a worktree is created at <repo>/.worktrees/<branch-with-/-replaced-by-->
#     - the tmux window is split vertically; top pane is a shell, bottom pane
#       runs `claude` (started via send-keys, so quitting claude leaves a shell)
#     - focus lands on the top pane
#   WINDOW_NAME=main always points at the original (non-worktree) checkout.
#   Running tm from inside an existing worktree to spawn another worktree is
#   refused.
#
# Cleanup:
#   tm -d <workspace> <branch>
#     kills the tmux window <workspace>:<branch> and removes the worktree at
#     <repo>/.worktrees/<branch-flattened>. The branch itself is not deleted.
#     To also delete the branch:  git -C <repo> branch -d <branch>
#
# To see all running sessions/windows + their cwds:
#   tmux list-windows -a -F '#S:#W  #{pane_current_path}'

function usage() {
  echo "USAGE: $ $(basename "$0") path/to/workspace [WINDOW_NAME] [CMD...]"
  echo "       $ $(basename "$0") -d path/to/workspace BRANCH"
  echo
  echo "  -d   delete: kill the tmux window and remove the git worktree"
  echo "       for BRANCH. Branch itself is not deleted."
}

function expand_workspace() {
  local ws="$1"
  local p=${TMPATH:-.}
  local IFS=":"
  read -ra TP <<< "$p"
  for x in "${TP[@]}"; do
    if [[ -d "$x/$ws" ]]; then
      cd "$x/$ws"
      pwd
      return
    fi
  done
}

enable_debugging="false"
function debug() {
  [[ "$enable_debugging" == "true" ]] && \
    [[ -n "$1" ]] && \
    echo "$1"
}

# --- git worktree helpers -----------------------------------------------------

function is_git_repo() {
  git -C "$1" rev-parse --git-dir >/dev/null 2>&1
}

# True iff $1 is a linked worktree (not the main checkout). Worktrees have a
# .git file pointing at <main>/.git/worktrees/<name>; main checkouts have a
# .git directory.
function is_worktree() {
  [[ -f "$1/.git" ]]
}

function flatten_branch() {
  echo "${1//\//-}"
}

function worktree_path() {
  local repo_root="$1" branch="$2"
  echo "$repo_root/.worktrees/$(flatten_branch "$branch")"
}

# Echoes the worktree path for $branch if one is already registered, else nothing.
function find_worktree() {
  local repo_root="$1" branch="$2"
  git -C "$repo_root" worktree list --porcelain 2>/dev/null | \
    awk -v want="branch refs/heads/$branch" '
      /^worktree / { wt = substr($0, 10) }
      $0 == want   { print wt; exit }
    '
}

function branch_exists() {
  local repo_root="$1" branch="$2"
  git -C "$repo_root" show-ref --verify --quiet "refs/heads/$branch" || \
    git -C "$repo_root" show-ref --verify --quiet "refs/remotes/origin/$branch"
}

# Echoes the worktree path on stdout, creating/reusing as needed.
# On failure, echoes nothing and returns non-zero.
function ensure_worktree() {
  local repo_root="$1" branch="$2"
  local existing
  existing=$(find_worktree "$repo_root" "$branch")
  if [[ -n "$existing" ]]; then
    echo "$existing"
    return 0
  fi
  local path
  path=$(worktree_path "$repo_root" "$branch")
  if branch_exists "$repo_root" "$branch"; then
    git -C "$repo_root" worktree add "$path" "$branch" >&2 || return 1
  else
    git -C "$repo_root" worktree add -b "$branch" "$path" >&2 || return 1
  fi
  echo "$path"
}

# Copy gitignored files into a worktree according to the patterns in
# <repo_root>/.worktreeinclude (same syntax as .gitignore). Per the
# .worktreeinclude convention: only files that match a pattern AND are
# gitignored are copied — tracked files are never duplicated. Existing
# files in the worktree are NEVER overwritten — only new entries are
# materialized, so the include file can be refined over time without
# clobbering edits in existing worktrees. No-op if .worktreeinclude is
# missing.
function process_worktreeinclude() {
  local repo_root="$1" wt_path="$2"
  local include_file="$repo_root/.worktreeinclude"
  [[ -f "$include_file" ]] || return 0

  local count=0 f src dest
  while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    git -C "$repo_root" check-ignore -q -- "$f" || continue
    src="$repo_root/$f"
    [[ -e "$src" ]] || continue
    dest="$wt_path/$f"
    [[ -e "$dest" ]] && continue
    mkdir -p "$(dirname "$dest")"
    cp -p "$src" "$dest"
    count=$((count + 1))
  done < <(git -C "$repo_root" ls-files --others -i --exclude-from="$include_file")

  if (( count > 0 )); then
    echo "tm: copied $count file(s) into worktree per .worktreeinclude" >&2
  fi
}

function setup_agent_pane() {
  local target="$1" dir="$2"
  tmux split-window -v -c "$dir" -t "$target"
  tmux send-keys -t "$target.1" 'claude' Enter
  tmux select-pane -t "$target.0"
}

# --- main ---------------------------------------------------------------------

DELETE_MODE="false"
if [[ "$1" == "-d" ]]; then
  DELETE_MODE="true"
  shift
fi

WORKSPACE="$1"

if [[ -z "$WORKSPACE" ]]; then
  if [[ "$DELETE_MODE" == "true" ]]; then
    usage >&2
    exit 1
  fi
  usage
  echo
  echo "Sessions:"
  tmux ls 2>/dev/null || echo "  (no tmux server)"
  echo
  echo "Windows:"
  tmux list-windows -a -F '  #S:#W  #{pane_current_path}' 2>/dev/null || true
  exit 0
fi

SESSION_NAME=$(basename "$WORKSPACE")
shift
if [[ -n "$1" ]]; then
  WINDOW_NAME_PROVIDED="true"
  WINDOW_NAME="$1"
else
  WINDOW_NAME_PROVIDED="false"
  WINDOW_NAME="main"
fi
shift
CMD=$@

# --- delete mode --------------------------------------------------------------
if [[ "$DELETE_MODE" == "true" ]]; then
  if [[ "$WINDOW_NAME_PROVIDED" != "true" ]]; then
    echo "tm -d: branch name required" >&2
    usage >&2
    exit 1
  fi
  if [[ "$WINDOW_NAME" == "main" ]]; then
    echo "tm -d: refusing to delete 'main' (not a worktree)" >&2
    exit 1
  fi
  workspace_dir=$(expand_workspace "$WORKSPACE")
  if [[ -z "$workspace_dir" ]]; then
    if [[ -d "$WORKSPACE" ]]; then
      workspace_dir=$(cd "$WORKSPACE" && pwd)
    else
      echo "tm -d: workspace not found in TMPATH or on filesystem: $WORKSPACE" >&2
      exit 1
    fi
  fi
  if ! is_git_repo "$workspace_dir"; then
    echo "tm -d: $workspace_dir is not a git repo" >&2
    exit 1
  fi
  if is_worktree "$workspace_dir"; then
    echo "tm -d: refusing to operate from inside a worktree: $workspace_dir" >&2
    exit 1
  fi
  repo_root=$(git -C "$workspace_dir" rev-parse --show-toplevel)
  target="$SESSION_NAME:$WINDOW_NAME"
  did_something="false"

  # Kill window if it exists in this session
  if tmux list-windows -t "$SESSION_NAME" -F '#W' 2>/dev/null | grep -qFx "$WINDOW_NAME"; then
    echo "tm -d: killing tmux window $target"
    tmux kill-window -t "$target"
    did_something="true"
  fi

  # Locate worktree (registered, else conventional path)
  wt_path=$(find_worktree "$repo_root" "$WINDOW_NAME")
  if [[ -z "$wt_path" ]]; then
    candidate=$(worktree_path "$repo_root" "$WINDOW_NAME")
    [[ -d "$candidate" ]] && wt_path="$candidate"
  fi

  if [[ -n "$wt_path" && -d "$wt_path" ]]; then
    echo "tm -d: removing worktree $wt_path"
    if ! git -C "$repo_root" worktree remove "$wt_path"; then
      echo "tm -d: worktree remove failed (uncommitted changes or untracked files?)" >&2
      echo "  to force: git -C $repo_root worktree remove --force $wt_path" >&2
      exit 1
    fi
    did_something="true"
  elif [[ -n "$wt_path" ]]; then
    # Registered but directory missing — prune the stale entry
    echo "tm -d: pruning stale worktree registration for $WINDOW_NAME"
    git -C "$repo_root" worktree prune
    did_something="true"
  fi

  if [[ "$did_something" == "false" ]]; then
    echo "tm -d: nothing to do (no window, no worktree for '$WINDOW_NAME')"
  fi
  exit 0
fi

mapfile -t sessions < <( tmux list-sessions -F "#{session_name}" 2>/dev/null )

for i in "${!sessions[@]}"; do
  name="${sessions[$i]}"
  if [[ "$name" == "$SESSION_NAME" ]]; then
    session_exist="true"
  fi
done

[[ -z "$session_exist" ]] && session_exist="false"

workspace_dir=$(expand_workspace "$WORKSPACE")

# Resolution order:
#   1. TMPATH match  -> use that dir
#   2. literal filesystem path (abs or relative, exists) -> use it
#   3. fallback: vanilla session name rooted at $HOME (e.g. `tm home`)
#
# The git-repo/worktree branch fires for (1) and (2) but not (3) — the
# fallback must never accidentally trigger worktree creation if $HOME
# happens to be a git repo.
resolved_kind="tmpath"
if [[ -z "$workspace_dir" ]]; then
  if [[ -d "$WORKSPACE" ]]; then
    workspace_dir=$(cd "$WORKSPACE" && pwd)
    resolved_kind="path"
  else
    workspace_dir="$HOME"
    resolved_kind="fallback"
  fi
fi

# Agent/worktree mode: explicit non-"main" WINDOW_NAME on a git workspace
# that was resolved to a real directory (TMPATH or filesystem path). In
# agent mode the CMD pass-through is intentionally ignored — the bottom
# pane runs claude and the top pane is a plain shell.
agent_window="false"
if [[ "$resolved_kind" != "fallback" ]] && [[ "$WINDOW_NAME" != "main" ]] && is_git_repo "$workspace_dir"; then
  if is_worktree "$workspace_dir"; then
    echo "tm: refusing to nest worktrees; $workspace_dir is itself a worktree" >&2
    exit 1
  fi
  repo_root=$(git -C "$workspace_dir" rev-parse --show-toplevel)
  workspace_dir=$(ensure_worktree "$repo_root" "$WINDOW_NAME") || {
    echo "tm: failed to create or resolve worktree for branch '$WINDOW_NAME'" >&2
    exit 1
  }
  # Always run — on fresh worktrees this seeds the includes, on existing
  # worktrees it only adds files that have since been added to
  # .worktreeinclude. Existing files in the worktree are never overwritten.
  process_worktreeinclude "$repo_root" "$workspace_dir"
  agent_window="true"
  CMD=""
fi

target="$SESSION_NAME:$WINDOW_NAME"

if [[ -n "$TMUX" ]]; then
  debug "in tmux"
  # we are currently in a tmux session
  current=$(tmux display-message -p '#{session_name}:#{window_name}')
  if [[ "$current" == "$target" ]]; then
    debug "current session and window"
    # we are already in this session and window
    exit 0
  elif echo "$current" | grep -q -e "^$SESSION_NAME:"; then
    debug "current session, not window"
    # we are in the session, but not attached to the requested window
    # attempt to make the window active in the session
    tmux select-window -t "$WINDOW_NAME" 2>/dev/null
    if [[ "$?" -ne "0" ]]; then
      debug "window didn't exist, create it"
      tmux new-window -c "$workspace_dir" -n "$WINDOW_NAME" $CMD
      [[ "$agent_window" == "true" ]] && setup_agent_pane "$target" "$workspace_dir"
    fi
  elif [[ "$session_exist" == "true" ]]; then
    debug "session exists, we aren't in it"
    # attempt to make the window active in the session
    tmux select-window -t "$target" 2>/dev/null
    if [[ "$?" -ne "0" ]]; then
      debug "window didn't exist, create it"
      # https://stackoverflow.com/questions/24100721/tmux-attach-to-a-session-and-specify-window
      # if it wasn't successful, then the window doesn't exist, create it but don't attach
      TMUX='' tmux new-window -a -c "$workspace_dir" -d -n "$WINDOW_NAME" -t "$SESSION_NAME" $CMD
      [[ "$agent_window" == "true" ]] && setup_agent_pane "$target" "$workspace_dir"
    fi
    tmux switch-client -t "$target"
  else
    debug "session doesn't exist"
    # session does not exist; create it, but do not attach
    # http://stackoverflow.com/questions/16398850/create-new-tmux-session-from-inside-a-tmux-session
    TMUX='' tmux new-session -c "$workspace_dir" -d -s "$SESSION_NAME" -n "$WINDOW_NAME" $CMD
    [[ "$agent_window" == "true" ]] && setup_agent_pane "$target" "$workspace_dir"
    tmux switch-client -t "$target"
  fi
else
  debug "not in tmux"
  # we are not currently in a tmux session
  if [[ "$session_exist" == "true" ]]; then
    debug "session exists"
    tmux select-window -t "$target" 2>/dev/null
    if [[ "$?" -ne "0" ]]; then
      debug "window didn't exist, create it"
      TMUX='' tmux new-window -a -c "$workspace_dir" -d -n "$WINDOW_NAME" -t "$SESSION_NAME" $CMD
      [[ "$agent_window" == "true" ]] && setup_agent_pane "$target" "$workspace_dir"
    fi
    tmux attach-session -t "$SESSION_NAME"
  else
    debug "session does not exist"
    # session does not exist, create it (detached) so we can set up the agent
    # pane if needed, then attach.
    TMUX='' tmux new-session -d -c "$workspace_dir" -s "$SESSION_NAME" -n "$WINDOW_NAME" $CMD
    [[ "$agent_window" == "true" ]] && setup_agent_pane "$target" "$workspace_dir"
    tmux attach-session -t "$SESSION_NAME"
  fi
fi
