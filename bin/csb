#!/usr/bin/env bash
#
# csb (claude sandbox)
#
# Runs Claude Code — or a shell — in a per-branch git worktree, inside the
# repo's own nix devShell, behind three layers:
#
#   1. env scrub     nix develop --ignore-environment + a small allowlist
#                    (extend with -k/--keep or a profile's keep=)
#   2. private HOME  HOME redirected to the per-namespace ~/.csb/claudes/<ns>
#                    (or a throwaway dir with -E) for the launched process only
#   3. fs sandbox    seatbelt (sandbox-exec) on macOS, bubblewrap on Linux:
#                    READS  default-allow minus a deny-list (~/.ssh, ~/.aws,
#                           ~/.gnupg, the real ~/.claude, other namespaces,
#                           browser profiles, packaging creds, ...), even by
#                           absolute path. Extend: ~/.config/csb/deny.
#                           --paranoid inverts this: real HOME is read-deny
#                           except the write-allow roots.
#                    WRITES default-deny plus an allow-list (worktree, git
#                           common dir minus hooks/config, namespace HOME,
#                           tmp dirs, /dev). Extend: ~/.config/csb/allow-write.
#                    On Linux the process also gets its own PID namespace
#                    (--unshare-pid): other processes are invisible.
#
# Network and host services stay OPEN by design (claude must reach local
# db/redis/etc for testing). The fs sandbox shrinks what can be read/written;
# it is not an egress firewall — anything readable is exfiltratable.
#
#   csb [BRANCH]            ensure a worktree for BRANCH (off current HEAD) and
#                           launch claude with the worktree as cwd
#   csb -y [BRANCH]         ...with --dangerously-skip-permissions (allow-all)
#   csb --here              launch in the current dir, no worktree (quick ops)
#   csb -s [BRANCH]         interactive bash instead of claude — same env
#   csb -n BRANCH           prepare/reuse the worktree only; don't launch
#   csb --ns NAME [BRANCH]  override the claude namespace (default: the branch)
#   csb -E [BRANCH]         ephemeral (throwaway) config, no namespace
#   csb -p NAME [BRANCH]    load defaults (ns/token_cmd/aws/keep/setenv) from a profile
#   csb --aws PROFILE ...   inject short-lived aws role credentials
#   csb [BRANCH] -- ARGS    pass ARGS to claude (with -s: run ARGS as the command)
#   csb -d BRANCH           remove the worktree for BRANCH AND its namespace config
#                           (the branch itself is NOT deleted)
#   csb                     list existing csb worktrees
#
# Namespaces partition claude's config (history/sessions/settings). By default
# the namespace IS the branch (percent-encoded): `csb feature/foo` uses a
# persistent config under ~/.csb/claudes/<repo-key>/feature%2Ffoo, reused on
# every later run for that branch. --ns NAME overrides the default; --ns @NAME
# is shared across repos; -E/--ephemeral opts out entirely. Every run is
# namespaced (or ephemeral) — the real ~/.claude is always denied, and 'global'
# is a reserved name. In --here mode the branch is taken from the current
# HEAD (a detached HEAD is an error — pass --ns or -E).
#
# The repo needs its own flake.nix with devShells.default (full toolchain);
# the claude binary comes from csb's OWN flake, so the repo never imports csb.
#
# Worktree prep (worktree mode, not --here): csb seeds gitignored files matching
# <repo>/.worktreeinclude, then — if the worktree has an executable
# .worktreesetup.sh — runs it with the branch name as $1 and the worktree as cwd.
# It runs every invocation (so write it idempotent) and aborts csb on a non-zero
# exit. TRUST MODEL: all nix eval/build/develop and the setup script run on the
# HOST, unsandboxed, exactly as before — only the final claude/bash process is
# wrapped by the deny-list. At launch, VAR=value lines from
# <worktree>/.worktreeenv are injected into the scrubbed environment —
# .worktreesetup.sh can generate it.
#
# Config (XDG_CONFIG_HOME honored; default ~/.config):
#   ~/.config/csb/config           machine config: tmpdir=PATH (scratch device
#                                  for the launched TMPDIR + ephemeral HOMEs)
#   ~/.config/csb/deny             extra read-deny paths, one per line, `~/`
#                                  expanded, `#` comments. ADD-ONLY: built-in
#                                  defaults can never be removed.
#   ~/.config/csb/allow-write      extra write-allow roots, same format.
#   ~/.config/csb/home/            template dir seeded (non-overwriting) into the
#                                  launched HOME each run — user-level files
#                                  (CLAUDE.md, settings.json, rules/) so
#                                  in-sandbox claude sees them. Per-profile
#                                  override: seed_home=. --reseed overwrites.
#   ~/.config/csb/profiles/<name>  launch profile for -p: KEY=VALUE lines with
#                                  keys ns, token_cmd, aws_profile, latest,
#                                  yolo, paranoid, here, ephemeral, shell,
#                                  seed_creds, seed_home, args, keep, setenv.
#
# Env:
#   CSB_SELF   flake ref to csb itself (default: the network-local git remote
#              git+ssh://git@git.grandrew.com/atongen/csb.git). Override for a
#              local working tree, e.g. CSB_SELF=path:/path/to/csb
#   CSB_LATEST if set (non-empty), default -L/--latest on: re-lock the claude-code
#              input to upstream HEAD each run instead of the committed flake.lock.

set -euo pipefail

PROG=$(basename "$0")

# csb supplies the claude binary from its own flake (so repos stay decoupled).
# Default: the network-local remote. For local dev against a working tree,
# override: CSB_SELF=path:/path/to/csb csb ...
CSB_SELF="${CSB_SELF:-git+ssh://git@git.grandrew.com/atongen/csb.git}"

CSB_NS_ROOT="$HOME/.csb/claudes"
CSB_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/csb"

usage() {
  cat <<EOF
USAGE:
  $PROG [OPTIONS] BRANCH [-- ARGS...]     worktree for BRANCH + claude in the devShell
  $PROG [OPTIONS] --here [-- ARGS...]     launch in the current dir (no worktree)
  $PROG -n BRANCH                         prepare BRANCH's worktree, don't launch
  $PROG -d BRANCH                         remove BRANCH's worktree (keeps the branch)
  $PROG                                   list csb worktrees

Claude (or the -s shell) runs inside the repo's devShell with a scrubbed
environment, a private per-namespace HOME, a read deny-list (~/.ssh, ~/.aws,
the real ~/.claude, etc. — extend via ~/.config/csb/deny), and a write
allow-list (worktree, git dir, namespace HOME, tmp — extend via
~/.config/csb/allow-write). Network and local services stay reachable.

OPTIONS:
  -y, --yolo         pass --dangerously-skip-permissions to claude (allow-all)
      --paranoid     tighten reads: instead of allow-minus-deny-list, make the
                     real HOME read-DENY except the write-allow roots (worktree,
                     git dir, namespace HOME, tmp). The redirected HOME keeps
                     tool caches working; add read paths via ~/.config/csb/
                     allow-write. Also via a profile's paranoid=true.
      --here         no worktree: run in the current directory (quick ops).
                     Mutually exclusive with BRANCH. The namespace comes from
                     the current HEAD branch (detached = error).
  -N, --ns NAME      override the claude namespace (default: the branch,
                     percent-encoded). Persistent, isolated config under
                     ~/.csb/claudes/<repo-key>/NAME. @NAME is unscoped — one
                     config shared across repos (~/.csb/claudes/@NAME); -d
                     never auto-removes @-namespaces. 'global' is reserved.
  -E, --ephemeral    throwaway config/HOME, no namespace (not persisted).
                     Mutually exclusive with --ns.
  -s, --shell        drop into an interactive bash — or run ARGS after -- as a
                     command — instead of claude, in the exact environment
                     claude would get: same worktree, devShell, env scrub,
                     HOME redirection, and deny-list.
  -k, --keep VAR     also keep env var VAR across the scrubbed environment.
                     Repeatable.
      --seed-creds   seed the HOST's native claude session credential into the
                     launch config (macOS keychain / linux ~/.claude), so the
                     sandbox presents your live subscription session instead
                     of a long-lived token. Shares the refresh-token family
                     with native claude. Also via a profile's seed_creds=true.
      --seed-home DIR
                     seed the launch HOME (non-overwriting) from template DIR:
                     user-level files (CLAUDE.md, settings.json, rules/) that
                     in-sandbox claude should otherwise miss (the real ~/.claude
                     is denied and HOME is redirected). Default ~/.config/csb/
                     home; also via a profile's seed_home=.
      --reseed       when seeding the launch HOME from the template, overwrite
                     existing files instead of keeping them (default: keep).
  -p, --profile NAME load launch defaults from ~/.config/csb/profiles/NAME
                     (ns=, token_cmd=, aws_profile=, latest=, yolo=, paranoid=,
                     here=, ephemeral=, shell=, seed_creds=, seed_home=, args=,
                     keep=, setenv=).
                     Optional [shared]/[claude]/[shell] sections let one file
                     serve both modes ([claude] applies to claude launches,
                     [shell] under -s; top-of-file lines are shared).
                     Explicit CLI flags beat profile values.
      --no-yolo, --no-paranoid, --no-here, --no-shell, --no-ephemeral,
      --no-latest, --no-seed-creds
                     negate the corresponding option, overriding a profile
                     (or, for latest, the CSB_LATEST env) default for one run
      --aws PROFILE  fetch short-lived credentials for aws profile PROFILE
                     host-side (aws configure export-credentials, with an sso
                     device-code login fallback) and inject them into the
                     launched environment. Creds do NOT refresh inside a
                     running session — re-launch to refresh.
  -n, --no-launch    prepare/reuse the worktree (incl. .worktreeinclude and
                     .worktreesetup.sh) and exit; prints the worktree path
  -L, --latest       get the very latest claude: re-lock the claude-code flake
                     input to its upstream HEAD for this run (bypassing the
                     committed flake.lock) and refresh nix's flake cache.
                     Trades reproducibility for always-newest. Default via
                     CSB_LATEST=1.
  -d, --delete       delete mode: remove BRANCH's worktree AND its namespace
                     config under ~/.csb/claudes (keeps the branch itself).
                     Pass the same --ns you launched with; without it, -d only
                     removes the branch-derived namespace.
  -h, --help         show this help
EOF
}

die() { echo "$PROG: $*" >&2; exit 1; }

# --- git / worktree helpers ---------------------------------------------------

# Map a branch name to one filesystem-safe path component, injectively:
# percent-encode the only chars that could collide (`%` first, then `/`). So
# `feature/foo` -> `feature%2Ffoo` while `feature-foo` maps to itself — the two
# can no longer share a dir (the old `/`->`-` flatten sent both to `feature-foo`).
encode_branch() {
  local s="$1"
  s="${s//%/%25}"
  s="${s//\//%2F}"
  echo "$s"
}

worktree_path() {
  local repo_root="$1" branch="$2"
  echo "$repo_root/.worktrees/$(encode_branch "$branch")"
}

# One stable, filesystem-safe identity component for the repo: basename of the
# physical main-checkout root plus a short hash of its full path. The hash keeps
# same-named checkouts (forks, copies) apart; resolving worktrees (common dir)
# and symlinks (pwd -P) first maps every path into the same repo onto one key.
# Namespaces are scoped by this key so equal branch names in different repos
# never share — or `-d` — each other's config.
repo_key() {
  local root="$1" main phys
  main=$(dirname "$(git -C "$root" rev-parse --path-format=absolute --git-common-dir)")
  phys=$(cd "$main" && pwd -P)
  printf '%s-%x\n' "$(basename "$phys")" "$(printf '%s' "$phys" | cksum | cut -d' ' -f1)"
}

# In a linked worktree, --git-dir and --git-common-dir differ.
in_worktree() {
  local gd cd
  gd=$(git rev-parse --path-format=absolute --git-dir 2>/dev/null) || return 1
  cd=$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null) || return 1
  [[ "$gd" != "$cd" ]]
}

# Echo the registered worktree path for $branch, else nothing.
find_worktree() {
  local repo_root="$1" branch="$2"
  git -C "$repo_root" worktree list --porcelain 2>/dev/null | \
    awk -v want="branch refs/heads/$branch" '
      /^worktree / { wt = substr($0, 10) }
      $0 == want   { print wt; exit }
    '
}

branch_exists() {
  local repo_root="$1" branch="$2"
  git -C "$repo_root" show-ref --verify --quiet "refs/heads/$branch" || \
    git -C "$repo_root" show-ref --verify --quiet "refs/remotes/origin/$branch"
}

# Echo the worktree path, creating/reusing as needed. Branch is created off the
# current HEAD if it doesn't already exist.
ensure_worktree() {
  local repo_root="$1" branch="$2" existing path
  existing=$(find_worktree "$repo_root" "$branch")
  if [[ -n "$existing" ]]; then
    # Reuse only a real csb worktree under .worktrees/. If the branch is checked
    # out elsewhere (commonly the main tree, when you're already on it), git
    # won't allow a second checkout — fail with guidance instead of returning
    # the wrong path.
    case "$existing" in
      "$repo_root"/.worktrees/*)
        echo "$existing"
        return 0
        ;;
      *)
        echo "$PROG: branch '$branch' is already checked out at: $existing" >&2
        echo "  a branch can live in only one worktree. Switch to your base branch" >&2
        echo "  (e.g. main) — or pick a different name — then: $PROG $branch" >&2
        return 1
        ;;
    esac
  fi
  path=$(worktree_path "$repo_root" "$branch")
  if branch_exists "$repo_root" "$branch"; then
    git -C "$repo_root" worktree add "$path" "$branch" >&2
  else
    git -C "$repo_root" worktree add -b "$branch" "$path" >&2
  fi
  echo "$path"
}

# Copy gitignored files matching <repo>/.worktreeinclude into a fresh worktree.
# Only files that match a pattern AND are gitignored are copied; existing files
# in the worktree are never overwritten. No-op if .worktreeinclude is missing.
process_worktreeinclude() {
  local repo_root="$1" wt_path="$2"
  local include_file="$repo_root/.worktreeinclude"
  [[ -f "$include_file" ]] || return 0

  local count=0 f src dest
  while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    git -C "$repo_root" check-ignore -q -- "$f" || continue
    src="$repo_root/$f"
    [[ -e "$src" ]] || continue
    dest="$wt_path/$f"
    [[ -e "$dest" ]] && continue
    mkdir -p "$(dirname "$dest")"
    # -R: nested git repos (e.g. bundler git-sourced gems) surface as single
    # directory entries in ls-files --others output.
    cp -pR "$src" "$dest"
    count=$((count + 1))
  done < <(git -C "$repo_root" ls-files --others -i --exclude-from="$include_file")

  if (( count > 0 )); then
    echo "$PROG: copied $count file(s) into worktree per .worktreeinclude" >&2
  fi
}

# Run <worktree>/.worktreesetup.sh (if present and executable) AFTER
# .worktreeinclude seeding, on every worktree invocation (incl. reuse and
# --no-launch). The branch name is passed as $1; the script runs with the
# worktree as its cwd. It's expected to be idempotent (it runs every launch). A
# non-zero exit aborts csb — a half-set-up worktree shouldn't launch claude.
# Running the worktree's OWN copy (not the main checkout's) lets each branch carry
# its own setup logic and composes with .worktreeinclude, which can seed a
# gitignored script before this runs. NOTE: like the repo's flake, this executes
# repo-controlled code on the HOST, unsandboxed — the deny-list wraps only the
# final claude/bash process.
process_worktreesetup() {
  local wt_path="$1" branch="$2"
  local setup="$wt_path/.worktreesetup.sh"
  [[ -e "$setup" ]] || return 0
  if [[ ! -x "$setup" ]]; then
    echo "$PROG: warning: $setup exists but is not executable; skipping" >&2
    echo "  (chmod +x it to have csb run it)" >&2
    return 0
  fi
  echo "$PROG: running .worktreesetup.sh $branch" >&2
  local rc=0
  ( cd "$wt_path" && "$setup" "$branch" ) || rc=$?
  if (( rc != 0 )); then
    die ".worktreesetup.sh failed (exit $rc); not launching claude.
  fix the script (or the worktree) and re-run $PROG"
  fi
}

# claude auths via a forwarded token: HOME is redirected away from any
# logged-in ~/.claude (which the deny-list blocks anyway), so a host login is
# never visible. Warn if nothing is exported to forward.
warn_if_no_token() {
  if [[ -z "${CLAUDE_CODE_OAUTH_TOKEN:-}" ]]; then
    echo "$PROG: warning: CLAUDE_CODE_OAUTH_TOKEN is not set;" >&2
    echo "  claude runs with a private HOME, so your host login isn't visible." >&2
    echo "  Generate a token once with 'claude setup-token' and export it —" >&2
    echo "  or set token_cmd in a profile (-p)." >&2
  fi
}

# Export the host's effective git identity as GIT_AUTHOR_*/GIT_COMMITTER_* so the
# agent can commit: HOME is redirected away from the real ~/.gitconfig (and the
# deny-list blocks it), so without these git wouldn't know who's committing.
# Left unset if git has no identity configured.
export_git_identity() {
  local git_name git_email
  git_name=$(git -C "$repo_root" config user.name 2>/dev/null || true)
  git_email=$(git -C "$repo_root" config user.email 2>/dev/null || true)
  if [[ -n "$git_name" ]]; then export GIT_AUTHOR_NAME="$git_name" GIT_COMMITTER_NAME="$git_name"; fi
  if [[ -n "$git_email" ]]; then export GIT_AUTHOR_EMAIL="$git_email" GIT_COMMITTER_EMAIL="$git_email"; fi
}

# Seed an onboarding-complete + folder-trusted .claude.json so interactive claude
# starts straight from CLAUDE_CODE_OAUTH_TOKEN instead of forcing a login/trust
# prompt (it does so even with the token in the env until onboarding is marked
# done). Host-side, into the namespace/throwaway config — never the real
# ~/.claude.json. Idempotent; a jq merge preserves any existing state, and a
# fresh file is written directly so the common case (new namespace) needs no jq.
#   $1 = path to the .claude.json to seed; $2 = project (cwd) key to trust
seed_claude_config() {
  local cfg="$1" proj="$2" base tmp
  mkdir -p "$(dirname "$cfg")"
  if command -v jq >/dev/null 2>&1; then
    base='{}'; [[ -s "$cfg" ]] && base="$(cat "$cfg")"
    tmp="$(mktemp)"
    printf '%s' "$base" | jq --arg p "$proj" \
      '.hasCompletedOnboarding = true
       | .projects[$p].hasTrustDialogAccepted = true
       | .projects[$p].projectOnboardingSeenCount = ((.projects[$p].projectOnboardingSeenCount) // 1)' \
      > "$tmp" && mv "$tmp" "$cfg"
  elif [[ ! -s "$cfg" ]]; then
    # No jq, but a fresh/empty file needs no merge — write the minimal seed. proj
    # is a filesystem path under the repo, so no JSON-significant chars are expected.
    cat > "$cfg" <<EOF
{
  "hasCompletedOnboarding": true,
  "projects": {
    "$proj": { "hasTrustDialogAccepted": true, "projectOnboardingSeenCount": 1 }
  }
}
EOF
  else
    echo "$PROG: warning: jq not found; can't merge the onboarding seed into the existing" >&2
    echo "  $cfg — claude may prompt for login/trust. Install jq." >&2
  fi
}

# Seed the launch HOME from a template dir so in-sandbox claude sees your
# user-level files — CLAUDE.md, settings.json, rules/, etc. — that otherwise
# live under the real ~/.claude (blocked by the deny-list) or elsewhere in the
# real HOME (hidden by HOME redirection). Copies the template's CONTENTS into
# the launch HOME, non-overwriting (existing files kept) unless --reseed is set.
# Runs host-side every launch (idempotent), so a freshly-created namespace is
# seeded on first use. Template dir: the profile's seed_home=, else
# ~/.config/csb/home. Narrow BY DESIGN — only what you place in the template is
# copied, never a blanket real-HOME sweep (which would re-expose exactly what
# the deny-list protects).
#   $1 = destination HOME (the namespace or ephemeral dir)
seed_home_template() {
  local dest="$1" tmpl explicit="false"
  if [[ -n "$seed_home" ]]; then tmpl="$seed_home"; explicit="true"; else tmpl="$CSB_CONFIG_DIR/home"; fi
  if [[ ! -d "$tmpl" ]]; then
    # A missing DEFAULT dir is the common case (no template configured) — silent.
    # A configured seed_home that doesn't resolve is likely a typo — say so.
    [[ "$explicit" == "true" ]] && echo "$PROG: warning: seed_home is not a directory: $tmpl (nothing seeded)" >&2
    return 0
  fi
  mkdir -p "$dest"
  local count=0 src rel target action
  # -type f only: reconstruct the tree file-by-file (parents via mkdir -p). cp -p
  # preserves the executable bit so seeded hooks/scripts stay runnable.
  while IFS= read -r -d '' src; do
    rel="${src#"$tmpl"/}"
    target="$dest/$rel"
    if [[ -e "$target" ]]; then
      [[ "$reseed" != "true" ]] && continue   # keep existing (default)
      action="reseeded (overwrote)"
    else
      action="seeded"
    fi
    mkdir -p "$(dirname "$target")"
    cp -p "$src" "$target"
    echo "$PROG: $action HOME/$rel" >&2
    count=$((count + 1))
  done < <(find "$tmpl" -mindepth 1 -type f -print0)
  # NB: an `if` block (not `(( count > 0 )) && echo`) so the function returns 0
  # when nothing was copied — under `set -e`, a trailing `&&` that short-circuits
  # would make this bare call abort csb on every no-op (re)launch.
  if (( count > 0 )); then
    echo "$PROG: seeded $count file(s) into HOME from $tmpl" >&2
  fi
}

# Resolve the effective claude namespace. Sets the global ns_dir (empty =
# ephemeral) and exports CSB_CLAUDE_CONFIG_DIR. Precedence:
#   -E/--ephemeral       -> throwaway config (no namespace)
#   --ns NAME (explicit) -> persistent ~/.csb/claudes/<repo-key>/NAME
#                           (@NAME: unscoped ~/.csb/claudes/@NAME)
#   default              -> persistent ~/.csb/claudes/<repo-key>/<branch>
# There is no sticky state: the default is derived from the branch every run, so
# `csb BRANCH` is deterministic without remembering anything. 'global' is a
# reserved name that errors at validation — every run is namespaced.
setup_namespace() {
  local worktree="$1" ns cur_branch
  ns_dir=""

  if [[ "$ephemeral" == "true" ]]; then
    export CSB_CLAUDE_CONFIG_DIR=""
    echo "$PROG: namespace: ephemeral  (throwaway config)" >&2
    return
  fi

  if [[ -n "$namespace" ]]; then
    ns="$namespace"
  elif [[ "$here" == "true" ]]; then
    # --here has no BRANCH arg: derive from the current HEAD branch. Fail fast
    # and loud on a detached HEAD rather than guessing.
    cur_branch=$(git -C "$worktree" branch --show-current 2>/dev/null || true)
    [[ -n "$cur_branch" ]] || die "--here on a detached HEAD: no branch to derive a namespace from.
  Pass --ns NAME or -E/--ephemeral explicitly."
    ns=$(encode_branch "$cur_branch")
  else
    ns=$(encode_branch "$branch")
  fi

  # The config dir is <ns>/.claude — not <ns> itself — so it coincides with
  # claude's default $HOME/.claude when csb redirects HOME to <ns> (.claude.json
  # follows CLAUDE_CONFIG_DIR when set). The fixed ~/.csb/claudes parent is
  # created as a side effect of this mkdir -p.
  # @NAME (explicit --ns only): deliberately unscoped — one dir shared across
  # repos, for a common claude home/config. Branch-derived names always stay
  # under the repo key, so a branch literally named '@x' cannot alias one.
  if [[ -n "$namespace" && "$namespace" == @* ]]; then
    ns_dir="$CSB_NS_ROOT/$ns"
    mkdir -p "$ns_dir/.claude"
    export CSB_CLAUDE_CONFIG_DIR="$ns_dir/.claude"
    echo "$PROG: namespace: $ns  (persistent, shared across repos: $ns_dir)" >&2
    return
  fi
  ns_dir="$CSB_NS_ROOT/$ns_repo_key/$ns"
  mkdir -p "$ns_dir/.claude"
  export CSB_CLAUDE_CONFIG_DIR="$ns_dir/.claude"
  echo "$PROG: namespace: $ns  (persistent: $ns_dir)" >&2
}

# --- deny-list / write policy -----------------------------------------------------
# Two filesystem policies for the launched process (and its children):
#   READS:  default-allow with a deny-list of sensitive paths (built-in floor +
#           add-only ~/.config/csb/deny), blocked even by absolute path. The
#           active namespace dir is re-allowed under the denied ~/.csb/claudes
#           parent; ephemeral HOMEs live under the tmp dir (not under any denied
#           path) so they need no re-allow.
#   WRITES: default-deny with an allow-list of roots — the worktree, the repo's
#           git common dir (minus hooks/ and config, which are host code-execution
#           vectors), the active namespace HOME, tmp dirs, /dev — plus add-only
#           ~/.config/csb/allow-write. This blocks persistence/escalation targets
#           (~/.zshrc, ~/bin, LaunchAgents, other checkouts) that a read deny-list
#           can't cover.

# Populate the global arrays deny_dirs / deny_files: built-in defaults + the
# user config, canonicalized (realpath — seatbelt matches resolved paths;
# symlinked HOMEs), missing paths skipped, classified dir vs file.
build_deny_paths() {
  deny_dirs=()
  deny_files=()
  local -a raw=(
    "$HOME/.ssh"
    "$HOME/.aws"
    "$HOME/.gnupg"
    "$HOME/.password-store"
    "$HOME/.claude"
    "$HOME/.claude.json"
    "$HOME/.csb/claudes"
    "$HOME/.netrc"
    "$HOME/.config/gh"
    "$HOME/.config/gcloud"
    "$HOME/.kube"
    "$HOME/.docker"
    "$HOME/.gitconfig"
    "$HOME/.config/git"
    "$HOME/.bash_history"
    "$HOME/.zsh_history"
    "$HOME/.cargo/credentials"
    "$HOME/.cargo/credentials.toml"
    "$HOME/.gem/credentials"
    "$HOME/.pypirc"
    "$HOME/.m2/settings.xml"
    # cloud / infra / secret-store credentials
    "$HOME/.azure"
    "$HOME/.oci"
    "$HOME/.vault-token"
    "$HOME/.terraformrc"
    "$HOME/.terraform.d"
    "$HOME/.granted"
    "$HOME/.databrickscfg"
    "$HOME/.databrickscfg.bak"
    "$HOME/.databricks"
    "$HOME/.config/doctl"
    "$HOME/.config/fly"
    "$HOME/.config/rclone"
    "$HOME/.config/op"
    "$HOME/.config/configstore"
    "$HOME/.config/github-copilot"
    "$HOME/.gemini"
    "$HOME/.mc"
    "$HOME/.minio"
    "$HOME/.s3cfg"
    "$HOME/.boto"
    "$HOME/.pgpass"
    "$HOME/.my.cnf"
    "$HOME/.claude.json.backup"
    # REPL / shell / editor history (can capture typed secrets)
    "$HOME/.python_history"
    "$HOME/.node_repl_history"
    "$HOME/.irb_history"
    "$HOME/.rdbg_history"
    "$HOME/.pry_history"
    "$HOME/.rediscli_history"
    "$HOME/.mysql_history"
    "$HOME/.psql_history"
    "$HOME/.psql_history.d"
    "$HOME/.sqlite_history"
    "$HOME/.scala_history"
    "$HOME/.scala_history_jline3"
    "$HOME/.dotty_history"
    "$HOME/.utop-history"
    "$HOME/.ammonite"
    "$HOME/.hivehistory"
    "$HOME/.lesshst"
    "$HOME/.viminfo"
    "$HOME/.local/share/fish/fish_history"
    "$HOME/.local/share/nvim/shada"
  )
  # NOT in the floor (may be needed for in-sandbox installs against private
  # registries): ~/.npmrc, ~/.bundle/config, ~/.yarnrc — add them to
  # ~/.config/csb/deny if your repos don't need them.
  if [[ "$(uname -s)" == "Darwin" ]]; then
    raw+=(
      "$HOME/Library/Keychains"
      "$HOME/Library/Cookies"
      "$HOME/Library/Safari"
      "$HOME/Library/Application Support/Google/Chrome"
      "$HOME/Library/Application Support/Firefox"
      "$HOME/.zsh_sessions"
    )
  else
    raw+=(
      "$HOME/.local/share/keyrings"
      "$HOME/.mozilla"
      "$HOME/.config/google-chrome"
      "$HOME/.config/chromium"
    )
  fi

  # User additions: one path per line, leading ~/ expanded, # comments and
  # blanks ignored. Anything else is a parse error — a misparsed deny file must
  # not silently launch unprotected.
  local deny_file="$CSB_CONFIG_DIR/deny" line lineno=0
  if [[ -f "$deny_file" ]]; then
    while IFS= read -r line || [[ -n "$line" ]]; do
      lineno=$((lineno + 1))
      [[ -z "$line" || "$line" == \#* ]] && continue
      # shellcheck disable=SC2088  # a LITERAL leading ~/ is the config syntax
      case "$line" in
        "~/"*) raw+=("$HOME/${line#\~/}") ;;
        /*)    raw+=("$line") ;;
        *)     die "deny config $deny_file:$lineno: not an absolute or ~/ path: '$line'" ;;
      esac
    done < "$deny_file"
  fi

  local p rp
  for p in "${raw[@]}"; do
    [[ -e "$p" ]] || continue
    rp=$(realpath "$p")
    # Both wrapper syntaxes quote paths; a double quote would break the seatbelt
    # profile, so refuse it rather than emit a broken (weaker) profile.
    [[ "$rp" == *'"'* ]] && die "deny path contains a double quote (unsupported): $rp"
    if [[ -d "$rp" ]]; then
      deny_dirs+=("$rp")
    else
      deny_files+=("$rp")
    fi
  done
}

# Populate the global write_roots array: the roots the launched process may
# write under. Everything else is read-only (or read-denied per the deny-list).
# The active namespace / ephemeral HOME is handled separately per platform.
# Consumes the globals worktree, claude_home, cfg_tmpdir.
build_write_roots() {
  write_roots=()
  local -a cand=("$worktree")
  local gc
  gc=$(git -C "$worktree" rev-parse --path-format=absolute --git-common-dir 2>/dev/null || true)
  # Commits from a linked worktree write objects/refs into the MAIN repo's git
  # dir, so it must be writable (hooks/ and config are re-denied afterwards).
  [[ -n "$gc" ]] && cand+=("$gc")
  [[ -n "$claude_home" && -z "$ns_dir" ]] && cand+=("$claude_home")
  [[ -n "$cfg_tmpdir" ]] && cand+=("$cfg_tmpdir")
  cand+=("/tmp")
  if [[ "$(uname -s)" == "Darwin" ]]; then
    # The per-user /var/folders/... dir (parent of $TMPDIR covers both the
    # T/ temp and C/ cache subdirs, which system frameworks write to) and the
    # device tree (ptys; the TUI writes its terminal).
    cand+=("$(dirname "$(realpath "${TMPDIR:-/tmp}")")" "/dev")
  else
    cand+=("/var/tmp")
  fi

  # User additions: ~/.config/csb/allow-write, same format as the deny file.
  local aw_file="$CSB_CONFIG_DIR/allow-write" line lineno=0
  if [[ -f "$aw_file" ]]; then
    while IFS= read -r line || [[ -n "$line" ]]; do
      lineno=$((lineno + 1))
      [[ -z "$line" || "$line" == \#* ]] && continue
      # shellcheck disable=SC2088  # a LITERAL leading ~/ is the config syntax
      case "$line" in
        "~/"*) cand+=("$HOME/${line#\~/}") ;;
        /*)    cand+=("$line") ;;
        *)     die "allow-write config $aw_file:$lineno: not an absolute or ~/ path: '$line'" ;;
      esac
    done < "$aw_file"
  fi

  local p rp
  for p in "${cand[@]}"; do
    [[ -n "$p" && -e "$p" ]] || continue
    rp=$(realpath "$p")
    [[ "$rp" == *'"'* ]] && die "allow-write path contains a double quote (unsupported): $rp"
    write_roots+=("$rp")
  done
}

# Assemble the global deny_wrapper argv that wraps the innermost command:
#   darwin -> (/usr/bin/sandbox-exec -f <generated profile>)
#   linux  -> (<store bwrap> --ro-bind / / ... --)
# Consumes ns_dir (set by setup_namespace; empty for ephemeral) to re-allow the
# active namespace, and build_write_roots for the write policy. sandbox-exec is
# deprecated-but-stable (nix's own darwin sandbox uses the same libsandbox); if
# it ever disappears, this helper is the single place to swap the mechanism.
build_deny_wrapper() {
  deny_wrapper=()
  build_deny_paths
  build_write_roots
  local ns_real="" gc_real="" hooks_deny="" config_deny="" real_home
  real_home=$(realpath "$HOME")
  if [[ -n "$ns_dir" ]]; then
    ns_real=$(realpath "$ns_dir")
  fi
  gc_real=$(git -C "$worktree" rev-parse --path-format=absolute --git-common-dir 2>/dev/null || true)
  [[ -n "$gc_real" ]] && gc_real=$(realpath "$gc_real")
  [[ -d "$gc_real/hooks" ]] && hooks_deny="$gc_real/hooks"
  [[ -f "$gc_real/config" ]] && config_deny="$gc_real/config"

  case "$(uname -s)" in
    Darwin)
      local profile p
      profile=$(mktemp "${TMPDIR:-/tmp}/csb-deny.XXXXXX")
      {
        echo "(version 1)"
        echo "(allow default)"
        # READ policy: deny-list (later rules win; the active namespace is
        # re-allowed under the denied ~/.csb/claudes parent).
        for p in "${deny_dirs[@]+"${deny_dirs[@]}"}"; do
          printf '(deny file* (subpath "%s"))\n' "$p"
        done
        for p in "${deny_files[@]+"${deny_files[@]}"}"; do
          printf '(deny file* (literal "%s"))\n' "$p"
        done
        # PARANOID reads: deny everything under the real HOME, then re-allow the
        # write roots (and the namespace, below) so the devShell still resolves.
        if [[ "$paranoid" == "true" ]]; then
          printf '(deny file-read* (subpath "%s"))\n' "$real_home"
          for p in "${write_roots[@]+"${write_roots[@]}"}"; do
            printf '(allow file-read* (subpath "%s"))\n' "$p"
          done
        fi
        if [[ -n "$ns_real" ]]; then
          printf '(allow file* (subpath "%s"))\n' "$ns_real"
        fi
        # WRITE policy: allow-list.
        echo "(deny file-write*)"
        for p in "${write_roots[@]+"${write_roots[@]}"}"; do
          printf '(allow file-write* (subpath "%s"))\n' "$p"
        done
        if [[ -n "$ns_real" ]]; then
          printf '(allow file-write* (subpath "%s"))\n' "$ns_real"
        fi
        # Host code-execution vectors inside the writable git common dir.
        [[ -n "$hooks_deny" ]]  && printf '(deny file-write* (subpath "%s"))\n' "$hooks_deny"
        [[ -n "$config_deny" ]] && printf '(deny file-write* (literal "%s"))\n' "$config_deny"
      } > "$profile"
      deny_wrapper=(/usr/bin/sandbox-exec -f "$profile")
      ;;
    Linux)
      # Store path resolved host-side (before the env scrub) so the wrapper
      # doesn't rely on bubblewrap being on any PATH. --unshare-pid: other
      # processes are invisible and unsignalable. No --unshare-net /
      # --unshare-ipc: open host access is a requirement.
      local bwrap_bin p
      bwrap_bin="$(nix build "$CSB_SELF#bwrap" --no-link --print-out-paths)/bin/bwrap"
      deny_wrapper=("$bwrap_bin" --ro-bind / / --dev-bind /dev /dev --proc /proc
                    --unshare-pid --die-with-parent)
      # PARANOID reads: blank the real HOME; the write-root binds below (and the
      # namespace bind) re-expose exactly what the devShell needs to read.
      [[ "$paranoid" == "true" ]] && deny_wrapper+=(--tmpfs "$real_home")
      # WRITE policy: rw-bind the allowed roots over the read-only root.
      for p in "${write_roots[@]+"${write_roots[@]}"}"; do
        deny_wrapper+=(--bind "$p" "$p")
      done
      [[ -n "$hooks_deny" ]]  && deny_wrapper+=(--ro-bind "$hooks_deny" "$hooks_deny")
      [[ -n "$config_deny" ]] && deny_wrapper+=(--ro-bind "$config_deny" "$config_deny")
      # READ policy: mount ordering matters — the ~/.csb/claudes parent is
      # tmpfs'd here, then the active namespace is bound back in (rw) last.
      for p in "${deny_dirs[@]+"${deny_dirs[@]}"}"; do
        deny_wrapper+=(--tmpfs "$p")
      done
      for p in "${deny_files[@]+"${deny_files[@]}"}"; do
        deny_wrapper+=(--ro-bind /dev/null "$p")
      done
      if [[ -n "$ns_real" ]]; then
        deny_wrapper+=(--bind "$ns_real" "$ns_real")
      fi
      deny_wrapper+=(--)
      ;;
    *)
      die "unsupported platform for the deny-list sandbox: $(uname -s)"
      ;;
  esac
}

# --- machine config / profiles / aws ----------------------------------------------

# Machine-level config: $CSB_CONFIG_DIR/config, KEY=VALUE lines ('#' comments).
# Recognized keys (anything else is an error):
#   tmpdir=PATH   tmp dir for the launched process (its TMPDIR), the ephemeral
#                 HOME, and a write-allow root — e.g. a scratch device.
load_config() {
  local f="$CSB_CONFIG_DIR/config" line key val lineno=0
  [[ -f "$f" ]] || return 0
  while IFS= read -r line || [[ -n "$line" ]]; do
    lineno=$((lineno + 1))
    [[ -z "$line" || "$line" == \#* ]] && continue
    [[ "$line" == *=* ]] || die "config $f:$lineno: expected KEY=VALUE: '$line'"
    key="${line%%=*}"
    val="${line#*=}"
    case "$key" in
      tmpdir)
        # shellcheck disable=SC2088  # a LITERAL leading ~/ is the config syntax
        case "$val" in
          "~/"*) val="$HOME/${val#\~/}" ;;
        esac
        [[ -d "$val" ]] || die "config $f:$lineno: tmpdir does not exist: '$val'"
        cfg_tmpdir=$(realpath "$val")
        ;;
      *) die "config $f:$lineno: unknown key '$key' (tmpdir)" ;;
    esac
  done < "$f"
}

# Seed the launch config dir with the HOST's native claude session credential
# (macOS: keychain item; linux: the real ~/.claude/.credentials.json, which the
# sandbox itself can't read). The sandbox then presents the same live
# subscription session as native claude — long-lived setup-tokens carry
# entitlements from mint time and can lag new model tiers. Runs host-side,
# every launch (keeps the copy fresh); the secret is never echoed. Note: the
# sandbox and native claude share one refresh-token family — occasional mutual
# re-login prompts are possible.
seed_credentials() {
  local dir="$1" blob src
  mkdir -p "$dir"
  if [[ "$(uname -s)" == "Darwin" ]]; then
    blob=$(security find-generic-password -a "$USER" -w -s "Claude Code-credentials" 2>/dev/null) \
      || die "seed_creds: no 'Claude Code-credentials' keychain item (log in with native claude first)"
    [[ "$blob" == *claudeAiOauth* ]] \
      || die "seed_creds: unexpected keychain blob shape (expected claudeAiOauth JSON)"
    (umask 077; printf '%s\n' "$blob" > "$dir/.credentials.json")
  else
    src="$HOME/.claude/.credentials.json"
    [[ -f "$src" ]] || die "seed_creds: $src not found (log in with native claude first)"
    (umask 077; cp "$src" "$dir/.credentials.json")
    chmod 600 "$dir/.credentials.json"
  fi
  echo "$PROG: seeded host session credentials into the launch config" >&2
}

# Validate a true|false profile value.
profile_bool() {
  local key="$1" val="$2" where="$3"
  [[ "$val" == "true" || "$val" == "false" ]] \
    || die "profile $where: $key needs true or false: '$val'"
}

# Dispatch one profile KEY=VALUE line. Writes load_profile's p_* locals via
# bash dynamic scoping. `shell=` is handled by load_profile itself (it selects
# which section applies, so it must be resolved before lines are dispatched).
apply_profile_line() {
  local f="$1" lineno="$2" line="$3" key val
  key="${line%%=*}"
  val="${line#*=}"
  case "$key" in
    ns)          p_ns="$val" ;;
    token_cmd)   token_cmd="$val" ;;
    aws_profile) p_aws="$val" ;;
    latest)      profile_bool latest    "$val" "$f:$lineno"; p_latest="$val" ;;
    yolo)        profile_bool yolo      "$val" "$f:$lineno"; p_yolo="$val" ;;
    paranoid)    profile_bool paranoid  "$val" "$f:$lineno"; p_paranoid="$val" ;;
    here)        profile_bool here      "$val" "$f:$lineno"; p_here="$val" ;;
    ephemeral)   profile_bool ephemeral "$val" "$f:$lineno"; p_ephemeral="$val" ;;
    seed_creds)  profile_bool seed_creds "$val" "$f:$lineno"; p_seed_creds="$val" ;;
    seed_home)
      # shellcheck disable=SC2088  # a LITERAL leading ~/ is the config syntax
      case "$val" in "~/"*) val="$HOME/${val#\~/}" ;; esac
      p_seed_home="$val" ;;
    args)        p_args="$val" ;;
    keep)        p_keep+=" $val" ;;
    setenv)
      [[ "$val" =~ ^[A-Za-z_][A-Za-z0-9_]*= ]] \
        || die "profile $f:$lineno: setenv needs VAR=value: '$val'"
      profile_setenv+=("$val")
      ;;
    *) die "profile $f:$lineno: unknown key '$key' (ns, token_cmd, aws_profile, latest, yolo, paranoid, here, ephemeral, shell, seed_creds, seed_home, args, keep, setenv)" ;;
  esac
}

# Parse ~/.config/csb/profiles/$profile_name and apply it as DEFAULTS: explicit
# CLI flags win — booleans track whether the CLI touched them (*_cli), so the
# --no-* flags can override a profile's true as well (and a profile's latest=
# beats the CSB_LATEST env default). Recognized keys (anything else is an error):
#   ns=NAME          as --ns
#   token_cmd=CMD    run host-side via bash -c; stdout -> CLAUDE_CODE_OAUTH_TOKEN
#                    (skipped in -s shell mode: no claude, no credential dance)
#   aws_profile=P    as --aws
#   latest=true      as -L/--latest      (true|false)
#   yolo=true        as -y/--yolo        (true|false)
#   paranoid=true    as --paranoid       (true|false; reads default-deny under
#                                         the real HOME, allowlist re-allows)
#   here=true        as --here           (true|false; an explicit BRANCH wins,
#                                         with a warning)
#   ephemeral=true   as -E/--ephemeral   (true|false; excludes ns= in the same
#                                         profile; an explicit --ns wins)
#   shell=true       as -s/--shell       (true|false; shared section only —
#                                         sets the default mode)
#   seed_creds=true  as --seed-creds     (true|false; seed the host claude
#                                         session into the launch config;
#                                         skipped in -s shell mode)
#   seed_home=DIR    as --seed-home; template dir copied (non-overwriting) into
#                    the launch HOME each run; default ~/.config/csb/home. Put
#                    user-level files here (CLAUDE.md, settings.json, rules/) so
#                    in-sandbox claude sees them. A leading ~/ expands to the
#                    HOST home. --reseed overwrites existing files.
#   args=WORD...     as the ARGS after -- (whitespace-split, no quoting; the
#                    shell command in -s mode, extra claude args otherwise).
#                    A leading ~/ or a literal ${HOME} in a word expands to the
#                    HOST home — args reference host-visible files (rcfiles,
#                    scripts), so this stays portable across macOS/Linux homes.
#                    (Contrast .worktreeenv, whose ${HOME} is the SANDBOX home.)
#   keep=V1 V2 ...   space-separated, appended to --keep
#   setenv=VAR=val   repeatable; appended to the launched env (post-scrub)
#
# SECTIONS: one profile file can serve both modes. Lines before any section
# header — or under [shared] — always apply; [claude] applies only when claude
# launches, [shell] only under -s. The mode is resolved first (CLI -s/--no-shell
# beats the shared section's shell=), then shared lines apply, then the active
# section's lines — so a section value overrides a shared one for scalar keys,
# while keep=/setenv= accumulate across both.
load_profile() {
  local f="$CSB_CONFIG_DIR/profiles/$profile_name" line lineno=0 section="shared"
  [[ -f "$f" ]] || die "profile not found: $f"
  local p_ns="" p_aws="" p_latest="" p_yolo="" p_paranoid="" p_here="" p_ephemeral="" \
        p_seed_creds="" p_seed_home="" p_args="" p_keep="" p_mode_shell="" v entry
  local -a keep_list=() shared_lines=() claude_lines=() shell_lines=()
  while IFS= read -r line || [[ -n "$line" ]]; do
    lineno=$((lineno + 1))
    [[ -z "$line" || "$line" == \#* ]] && continue
    case "$line" in
      "[shared]") section="shared"; continue ;;
      "[claude]") section="claude"; continue ;;
      "[shell]")  section="shell";  continue ;;
      "["*) die "profile $f:$lineno: unknown section '$line' (use [shared], [claude], or [shell])" ;;
    esac
    [[ "$line" == *=* ]] || die "profile $f:$lineno: expected KEY=VALUE: '$line'"
    if [[ "$line" == shell=* ]]; then
      [[ "$section" == "shared" ]] \
        || die "profile $f:$lineno: shell= is only valid in the shared section (it selects which section applies)"
      profile_bool shell "${line#shell=}" "$f:$lineno"
      p_mode_shell="${line#shell=}"
      continue
    fi
    case "$section" in
      shared) shared_lines+=("$lineno:$line") ;;
      claude) claude_lines+=("$lineno:$line") ;;
      shell)  shell_lines+=("$lineno:$line") ;;
    esac
  done < "$f"

  # Resolve the mode before dispatching lines: CLI beats the profile default.
  if [[ -n "$p_mode_shell" && "$shell_cli" != "true" ]]; then
    shell="$p_mode_shell"
  fi

  for entry in "${shared_lines[@]+"${shared_lines[@]}"}"; do
    apply_profile_line "$f" "${entry%%:*}" "${entry#*:}"
  done
  if [[ "$shell" == "true" ]]; then
    for entry in "${shell_lines[@]+"${shell_lines[@]}"}"; do
      apply_profile_line "$f" "${entry%%:*}" "${entry#*:}"
    done
  else
    for entry in "${claude_lines[@]+"${claude_lines[@]}"}"; do
      apply_profile_line "$f" "${entry%%:*}" "${entry#*:}"
    done
  fi

  if [[ -n "$p_ns" && "$p_ephemeral" == "true" ]]; then
    die "profile $f: ns and ephemeral=true are mutually exclusive"
  fi
  # ephemeral before ns: an applied ephemeral=true suppresses nothing (the two
  # can't coexist in one profile), but an explicit --ns must suppress it.
  if [[ -n "$p_ephemeral" && "$ephemeral_cli" != "true" && -z "$namespace" ]]; then
    ephemeral="$p_ephemeral"
  fi
  if [[ -n "$p_ns" && -z "$namespace" && "$ephemeral" != "true" ]]; then
    namespace="$p_ns"
  fi
  if [[ -n "$p_aws" && -z "$aws_profile" ]]; then
    aws_profile="$p_aws"
  fi
  if [[ -n "$p_latest" && "$latest_cli" != "true" ]]; then
    latest="$p_latest"
  fi
  if [[ -n "$p_yolo" && "$yolo_cli" != "true" ]]; then
    yolo="$p_yolo"
  fi
  if [[ -n "$p_paranoid" && "$paranoid_cli" != "true" ]]; then
    paranoid="$p_paranoid"
  fi
  if [[ -n "$p_here" && "$here_cli" != "true" ]]; then
    if [[ "$p_here" == "true" && -n "$branch" ]]; then
      echo "$PROG: warning: profile here=true overridden by BRANCH '$branch' (worktree mode)" >&2
    else
      here="$p_here"
    fi
  fi
  if [[ -n "$p_seed_creds" && "$seed_creds_cli" != "true" ]]; then
    seed_creds="$p_seed_creds"
  fi
  # emptiness-guarded like ns/aws_profile: an explicit --seed-home (non-empty)
  # beats the profile value.
  if [[ -n "$p_seed_home" && -z "$seed_home" ]]; then
    seed_home="$p_seed_home"
  fi
  if [[ -n "$p_args" && "$claude_args_cli" != "true" ]]; then
    local -a args_words=()
    local w
    read -ra args_words <<< "$p_args"
    claude_args=()
    # shellcheck disable=SC2016,SC2088  # matching the LITERAL strings ${HOME} and ~/
    for w in "${args_words[@]+"${args_words[@]}"}"; do
      w="${w//'${HOME}'/$HOME}"
      if [[ "$w" == "~/"* ]]; then
        w="$HOME/${w#\~/}"
      fi
      claude_args+=("$w")
    done
  fi
  read -ra keep_list <<< "$p_keep"
  for v in "${keep_list[@]+"${keep_list[@]}"}"; do
    [[ "$v" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]] || die "profile $f: invalid keep var name: '$v'"
    extra_keep+=("$v")
  done
  echo "$PROG: profile: $profile_name" >&2
}

# Run the profile's token_cmd host-side; stdout becomes CLAUDE_CODE_OAUTH_TOKEN
# (never echoed). Failure or empty output aborts the launch — before any
# worktree/namespace side effects.
run_token_cmd() {
  [[ -n "$token_cmd" ]] || return 0
  local tok
  tok=$(bash -c "$token_cmd") || die "profile token_cmd failed: $token_cmd"
  [[ -n "$tok" ]] || die "profile token_cmd produced no output: $token_cmd"
  export CLAUDE_CODE_OAUTH_TOKEN="$tok"
}

# Fetch short-lived role credentials for $aws_profile host-side and stage them
# for the launched environment (env overrides, NOT --keep: the values must not
# need to preexist in the caller's env). Requires the aws CLI on the HOST only.
fetch_aws_creds() {
  aws_env=()
  [[ -n "$aws_profile" ]] || return 0
  command -v aws >/dev/null 2>&1 || die "--aws requires the aws CLI on the host"
  local creds
  if ! creds=$(aws configure export-credentials --profile "$aws_profile" --format env 2>/dev/null); then
    echo "$PROG: no valid credentials for '$aws_profile'; trying sso device-code login" >&2
    aws sso login --profile "$aws_profile" --use-device-code \
      || die "aws sso login --profile '$aws_profile' failed"
    creds=$(aws configure export-credentials --profile "$aws_profile" --format env) \
      || die "aws configure export-credentials failed for '$aws_profile' after login"
  fi
  local line kv expiry="" region
  while IFS= read -r line; do
    kv="${line#export }"
    case "$kv" in
      AWS_ACCESS_KEY_ID=*|AWS_SECRET_ACCESS_KEY=*|AWS_SESSION_TOKEN=*)
        aws_env+=("$kv") ;;
      AWS_CREDENTIAL_EXPIRATION=*)
        aws_env+=("$kv"); expiry="${kv#*=}" ;;
    esac
  done <<< "$creds"
  [[ ${#aws_env[@]} -gt 0 ]] || die "no credentials parsed from aws export-credentials for '$aws_profile'"
  # export-credentials does not emit the region; inject it when configured.
  region=$(aws configure get region --profile "$aws_profile" 2>/dev/null || true)
  if [[ -n "$region" ]]; then
    aws_env+=("AWS_REGION=$region")
  fi
  # Role creds live ~1h and do NOT refresh inside a running session; make
  # staleness visible at launch.
  echo "$PROG: aws credentials for '$aws_profile'${expiry:+ (expire: $expiry)}" >&2
}

# --- argument parsing -----------------------------------------------------------

mode="launch"
no_launch="false"
namespace=""
profile_name=""
aws_profile=""
token_cmd=""
# Booleans a profile can default: each tracks whether the CLI set it (*_cli),
# in either direction (-X / --no-X) — CLI beats profile beats env default.
yolo="false";       yolo_cli="false"
paranoid="false";   paranoid_cli="false"
shell="false";      shell_cli="false"
here="false";       here_cli="false"
ephemeral="false";  ephemeral_cli="false"
seed_creds="false"; seed_creds_cli="false"
latest="false";     latest_cli="false"
[[ -n "${CSB_LATEST:-}" ]] && latest="true"
claude_args_cli="false"
reseed="false"      # --reseed: overwrite existing files when seeding the HOME
cfg_tmpdir=""
seed_home=""        # --seed-home / profile seed_home=; empty -> ~/.config/csb/home
branch=""
claude_args=()
extra_keep=()
profile_setenv=()
aws_env=()
ns_dir=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) usage; exit 0 ;;
    -d|--delete) mode="delete"; shift ;;
    -y|--yolo) yolo="true"; yolo_cli="true"; shift ;;
    --no-yolo) yolo="false"; yolo_cli="true"; shift ;;
    --paranoid) paranoid="true"; paranoid_cli="true"; shift ;;
    --no-paranoid) paranoid="false"; paranoid_cli="true"; shift ;;
    -n|--no-launch) no_launch="true"; shift ;;
    --here) here="true"; here_cli="true"; shift ;;
    --no-here) here="false"; here_cli="true"; shift ;;
    -s|--shell) shell="true"; shell_cli="true"; shift ;;
    --no-shell) shell="false"; shell_cli="true"; shift ;;
    -N|--ns) [[ $# -ge 2 ]] || die "--ns requires a NAME"; namespace="$2"; shift 2 ;;
    -E|--ephemeral) ephemeral="true"; ephemeral_cli="true"; shift ;;
    --no-ephemeral) ephemeral="false"; ephemeral_cli="true"; shift ;;
    -L|--latest) latest="true"; latest_cli="true"; shift ;;
    --no-latest) latest="false"; latest_cli="true"; shift ;;
    --seed-creds) seed_creds="true"; seed_creds_cli="true"; shift ;;
    --no-seed-creds) seed_creds="false"; seed_creds_cli="true"; shift ;;
    --seed-home) [[ $# -ge 2 ]] || die "--seed-home requires a DIR"; seed_home="$2"; shift 2 ;;
    --reseed) reseed="true"; shift ;;
    -k|--keep)
      [[ $# -ge 2 ]] || die "--keep requires a VAR name"
      [[ "$2" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]] || die "invalid env var name for --keep: '$2'"
      extra_keep+=("$2"); shift 2 ;;
    -p|--profile) [[ $# -ge 2 ]] || die "--profile requires a NAME"; profile_name="$2"; shift 2 ;;
    --aws) [[ $# -ge 2 ]] || die "--aws requires an aws PROFILE name"; aws_profile="$2"; shift 2 ;;
    --no-sandbox) die "--no-sandbox was removed: the devShell launch is the only mode; drop the flag" ;;
    --) shift; claude_args+=("$@"); claude_args_cli="true"; break ;;
    -*) usage >&2; die "unknown option: $1" ;;
    *)
      if [[ -z "$branch" ]]; then
        branch="$1"; shift
      else
        die "unexpected argument: $1"
      fi
      ;;
  esac
done

# --here means "no worktree": a BRANCH argument would be ignored, so reject it.
if [[ "$here" == "true" && -n "$branch" ]]; then
  die "--here and BRANCH are mutually exclusive (either provision a worktree for BRANCH, or run --here)"
fi

# --ns and -E are mutually exclusive: one names a namespace, the other opts out.
if [[ -n "$namespace" && "$ephemeral" == "true" ]]; then
  die "--ns and -E/--ephemeral are mutually exclusive"
fi

load_config

# Profile values are defaults; explicit CLI flags (checked above) beat them.
if [[ -n "$profile_name" ]]; then
  load_profile
fi

# Validate the namespace name: named namespaces become a directory under
# ~/.csb/claudes. A leading @ marks a deliberately unscoped (cross-repo shared)
# namespace. 'global' is reserved; a branch literally named "global" is fine
# (derived names are never special).
if [[ -n "$namespace" ]]; then
  if [[ "$namespace" == "global" ]]; then
    die "'global' is a reserved namespace name; every run is namespaced.
  Use --ns NAME (or --ns @NAME shared across repos), or -E for a throwaway config."
  fi
  [[ "$namespace" =~ ^@?[A-Za-z0-9._-]+$ && "$namespace" != "." && "$namespace" != ".." ]] \
    || die "invalid namespace '$namespace' (use letters, digits, . _ -; optional leading @)"
fi

if [[ "$yolo" == "true" ]]; then
  if [[ "$shell" == "true" ]]; then
    echo "$PROG: warning: -y/--yolo has no effect with --shell (ignored)" >&2
  else
    claude_args=("--dangerously-skip-permissions" "${claude_args[@]+"${claude_args[@]}"}")
  fi
fi

# Host-side credential work, before any worktree/namespace side effects (a
# token_cmd or aws failure must abort a clean launch, not a half-prepared one).
# Skipped for delete/list/prepare-only invocations, which launch nothing; the
# -s shell skips token_cmd too (it runs no claude — no reason to touch the
# password store), but keeps --aws (useful in a shell).
if [[ "$mode" == "launch" && "$no_launch" != "true" ]]; then
  [[ "$shell" == "true" ]] || run_token_cmd
  fetch_aws_creds
fi

# --- locate repo ----------------------------------------------------------------

git rev-parse --git-dir >/dev/null 2>&1 || die "not in a git repository"
repo_root=$(git rev-parse --show-toplevel)
ns_repo_key=$(repo_key "$repo_root")

# --- list mode (no branch, launch, not --here) ------------------------------------

if [[ "$mode" == "launch" && -z "$branch" && "$here" != "true" ]]; then
  echo "csb worktrees under $repo_root/.worktrees:"
  # `|| true` keeps pipefail from tripping when there are no matching worktrees
  # (awk exits 0 either way) or `git worktree list` fails outside a repo.
  git -C "$repo_root" worktree list 2>/dev/null \
    | awk -v pre="$repo_root/.worktrees/" 'index($1, pre) == 1' || true
  exit 0
fi

# The worktree flow operates from the main checkout; --here intentionally runs
# in the current dir (which may itself be a worktree), so skip the guard there.
if [[ "$here" != "true" ]] && in_worktree; then
  die "refusing to operate from inside a worktree: $repo_root
  run $PROG from the main checkout instead"
fi

# --- delete mode ------------------------------------------------------------------

if [[ "$mode" == "delete" ]]; then
  [[ -n "$branch" ]] || die "delete mode requires a branch name"
  wt_path=$(find_worktree "$repo_root" "$branch")
  if [[ -z "$wt_path" ]]; then
    candidate=$(worktree_path "$repo_root" "$branch")
    [[ -d "$candidate" ]] && wt_path="$candidate"
  fi
  if [[ -z "$wt_path" ]]; then
    echo "$PROG: no worktree for '$branch'"
  elif [[ -d "$wt_path" ]]; then
    echo "$PROG: removing worktree $wt_path"
    if ! git -C "$repo_root" worktree remove "$wt_path"; then
      echo "$PROG: worktree remove failed (uncommitted or untracked files?)" >&2
      echo "  to force: git -C $repo_root worktree remove --force $wt_path" >&2
      exit 1
    fi
  else
    echo "$PROG: pruning stale worktree registration for '$branch'"
    git -C "$repo_root" worktree prune
  fi

  # Also remove the persistent namespace config for this branch. Leaving stale
  # per-branch configs (session history + the auth they were seeded with) around
  # is a footprint/credential risk. Skip when an override makes removal unsafe or
  # irrelevant (-E: nothing persisted).
  if [[ "$ephemeral" != "true" ]]; then
    if [[ "$namespace" == @* ]]; then
      # Shared across repos: its lifecycle must not be a side effect of
      # deleting one branch's worktree.
      echo "$PROG: namespace '$namespace' is shared across repos — not removing." >&2
      echo "  to retire it deliberately: rm -rf $CSB_NS_ROOT/$namespace" >&2
    else
      ns_name="${namespace:-$(encode_branch "$branch")}"
      ns_dir="$CSB_NS_ROOT/$ns_repo_key/$ns_name"
      if [[ -d "$ns_dir" ]]; then
        echo "$PROG: removing namespace config $ns_dir"
        rm -rf "$ns_dir"
      fi
    fi
  fi
  exit 0
fi

# --- launch mode ------------------------------------------------------------------

if [[ "$here" == "true" ]]; then
  # No worktree: run in the current directory (quick/lightweight ops). cwd is
  # the live checkout, so it's less isolated than a worktree.
  worktree="$PWD"
else
  [[ -n "$branch" ]] || die "branch name required"
  worktree=$(ensure_worktree "$repo_root" "$branch") || exit 1
  process_worktreeinclude "$repo_root" "$worktree"
  process_worktreesetup "$worktree" "$branch"
fi
# --no-launch is purely a worktree-prep step (the namespace only matters at
# launch), so exit before setup_namespace — no stray ~/.csb/claudes dir.
if [[ "$no_launch" == "true" ]]; then
  if [[ "$here" == "true" ]]; then
    echo "$PROG: --no-launch: nothing to prepare for --here" >&2
  else
    echo "$PROG: prepared worktree (not launching claude)" >&2
  fi
  echo "$worktree"
  exit 0
fi

[[ -f "$worktree/flake.nix" ]] || die "$PROG runs inside the repo's devShell, but there is no flake.nix at $worktree
  the repo needs its own flake.nix with devShells.default (nix flake init -t $CSB_SELF)"

# flake.nix exists but may lack a devShell for this system. nix flakes ignore
# UNTRACKED files, so a brand-new flake.nix that hasn't been `git add`ed is
# invisible here (and to nix develop). Eval it to turn nix develop's cryptic
# 'does not provide attribute' into real guidance.
case "$(uname -s)-$(uname -m)" in
  Darwin-arm64)              csb_system="aarch64-darwin" ;;
  Darwin-x86_64)             csb_system="x86_64-darwin" ;;
  Linux-x86_64)              csb_system="x86_64-linux" ;;
  Linux-aarch64|Linux-arm64) csb_system="aarch64-linux" ;;
  *)                         csb_system="" ;;
esac
if [[ -n "$csb_system" ]] && \
   ! nix eval "$worktree#devShells.$csb_system.default.name" >/dev/null 2>&1; then
  die "flake.nix at $worktree has no devShells.$csb_system.default that $PROG can enter
  add one (nix flake init -t $CSB_SELF); if it is new, 'git add' it -- nix ignores untracked files"
fi

setup_namespace "$worktree"

cd "$worktree"

# Git identity for the agent's commits (see the helper).
export_git_identity

# -L/--latest: re-lock the claude-code input to its upstream HEAD for this run
# and refresh nix's flake cache so it re-fetches, instead of using the
# claude-code rev pinned in CSB_SELF's committed flake.lock. This defeats the
# lock (and nix's ~1h tarball cache) to give the newest claude at the cost of
# reproducibility + a fetch/eval on launch. Empty array = use the lock as-is.
# The input name must match flake.nix's inputs.claude-code.
nix_latest_args=()
if [[ "$latest" == "true" ]]; then
  nix_latest_args=(--override-input claude-code github:sadjow/claude-code-nix --refresh)
  echo "$PROG: --latest: re-locking claude-code to upstream HEAD (ignoring flake.lock pin)" >&2
fi

# Per-namespace HOME/config for the *launched* process only, injected via an
# `env` wrapper on the command — NOT exported into csb. csb's own `nix build`/
# `nix develop` must keep the real HOME so nix can read ~/.config/nix, its eval
# cache, and the ssh keys / tokens needed to fetch CSB_SELF and the repo's
# flake inputs (all nix runs host-side, unsandboxed — the trust model).
#  - persistent namespace -> HOME=<ns>, CLAUDE_CONFIG_DIR=<ns>/.claude (set
#    explicitly so .claude.json lands there too).
#  - -E/--ephemeral        -> a throwaway HOME under $TMPDIR (the OS reaps it;
#    deliberately not under any denied path, so it needs no re-allow).
env_overrides=()
if [[ -n "${CSB_CLAUDE_CONFIG_DIR:-}" ]]; then
  claude_home="$(dirname "$CSB_CLAUDE_CONFIG_DIR")"
  env_overrides=("HOME=$claude_home" "CLAUDE_CONFIG_DIR=$CSB_CLAUDE_CONFIG_DIR")
  claude_json="$CSB_CLAUDE_CONFIG_DIR/.claude.json"
else
  claude_home="$(mktemp -d "${cfg_tmpdir:-${TMPDIR:-/tmp}}/csb-home.XXXXXX")"
  env_overrides=("HOME=$claude_home")
  claude_json="$claude_home/.claude.json"
  echo "$PROG: ephemeral HOME: $claude_home" >&2
fi
# Seed user-level files into the launch HOME from the template dir, BEFORE the
# onboarding seed below so a template-provided .claude.json is merged (via jq),
# not overwritten.
seed_home_template "$claude_home"
seed_claude_config "$claude_json" "$worktree"
if [[ -n "$cfg_tmpdir" ]]; then
  env_overrides+=("TMPDIR=$cfg_tmpdir")
fi
# Host-session credential seeding (see the helper). The -s shell runs no
# claude, so it gets no credential dance at all (and no token warning); the
# seeded session makes the token warning moot otherwise.
if [[ "$shell" == "true" ]]; then
  :
elif [[ "$seed_creds" == "true" ]]; then
  seed_credentials "${CSB_CLAUDE_CONFIG_DIR:-$claude_home/.claude}"
else
  warn_if_no_token
fi

# Repo/branch-scoped env overrides: dotenv-style VAR=value lines from
# <worktree>/.worktreeenv (blank and # lines skipped). Injected through the
# same `env` wrapper as HOME — after the --ignore-environment scrub, inside
# the devShell, identically for claude and --shell. Repo-controlled like
# .worktreesetup.sh, which typically generates it per-branch. A literal
# ${HOME} in a value expands to the launch's EFFECTIVE home (the namespace
# dir when redirected, the real one otherwise) — generators run on the host
# before the namespace is resolved, so they can't know this path themselves.
if [[ -f "$worktree/.worktreeenv" ]]; then
  wte_count=0
  wte_home="${claude_home:-$HOME}"
  while IFS= read -r wte_line; do
    [[ -z "$wte_line" || "$wte_line" == \#* ]] && continue
    if [[ "$wte_line" =~ ^[A-Za-z_][A-Za-z0-9_]*= ]]; then
      # shellcheck disable=SC2016  # replacing the LITERAL string ${HOME}
      env_overrides+=("${wte_line//'${HOME}'/$wte_home}")
      wte_count=$((wte_count + 1))
    else
      echo "$PROG: warning: ignoring malformed .worktreeenv line: $wte_line" >&2
    fi
  done < "$worktree/.worktreeenv"
  (( wte_count > 0 )) && echo "$PROG: $wte_count env override(s) from .worktreeenv" >&2
  # Global excludes (core.excludesFile) live under the real HOME, which csb
  # redirects away — so check ignore status the way sandboxed git will see it,
  # and nudge toward the HOME-independent exclude file.
  if ! GIT_CONFIG_GLOBAL=/dev/null git -C "$worktree" check-ignore -q -- .worktreeenv 2>/dev/null; then
    echo "$PROG: note: .worktreeenv is not git-ignored inside the sandbox (global" >&2
    echo "  excludes are not read there) — add it to <repo>/.git/info/exclude" >&2
  fi
fi

# Profile setenv= and --aws credentials, after .worktreeenv (user config beats
# the repo file when both set a var — later `env` args win).
env_overrides+=("${profile_setenv[@]+"${profile_setenv[@]}"}")
env_overrides+=("${aws_env[@]+"${aws_env[@]}"}")

# The deny-list wraps the innermost command only; nix eval/build/develop above
# and below run host-side with the real HOME, unrestricted.
build_deny_wrapper

echo "$PROG: launching in the devShell at $worktree" >&2
echo "$PROG:   scrubbed env, HOME=$claude_home, fs deny-list on; network OPEN" >&2

# Scrub the environment, re-admit only an allowlist (+ --keep VARs). nix sets
# PATH/toolchain from the devShell, so `env` and the absolute paths resolve.
# HOME is kept (real) so the devShell shellHook has one; the `env` wrapper then
# overrides HOME for the launched process and its children. SSH_AUTH_SOCK is
# deliberately NOT kept — SSH push/fetch stays in your own shell.
# __NIXOS_SET_ENVIRONMENT_DONE: on NixOS, an interactive bash (SYS_BASHRC =
# /etc/bashrc) re-sources /etc/set-environment when the guard var is missing,
# clobbering the devShell PATH. Keeping it is a no-op elsewhere.
keep_vars=(HOME USER TERM LANG LC_ALL CLAUDE_CODE_OAUTH_TOKEN
           GIT_AUTHOR_NAME GIT_AUTHOR_EMAIL GIT_COMMITTER_NAME GIT_COMMITTER_EMAIL
           __NIXOS_SET_ENVIRONMENT_DONE)
keep_vars+=("${extra_keep[@]+"${extra_keep[@]}"}")
keep_args=()
for v in "${keep_vars[@]}"; do keep_args+=(--keep "$v"); done

# --shell: same worktree/devShell/scrub/HOME/deny-list, but exec an interactive
# bash (or the args after --) instead of claude. No claude build needed.
if [[ "$shell" == "true" ]]; then
  cmd=(bash)
  [[ ${#claude_args[@]} -gt 0 ]] && cmd=("${claude_args[@]}")
  echo "$PROG: shell in the devShell at $worktree (claude's env, no claude)" >&2
  exec nix develop "$worktree" --ignore-environment "${keep_args[@]}" \
    --command env "${env_overrides[@]+"${env_overrides[@]}"}" \
      "${deny_wrapper[@]}" "${cmd[@]}"
fi

claude_bin="$(nix build "${CSB_SELF}#claude" "${nix_latest_args[@]+"${nix_latest_args[@]}"}" --no-link --print-out-paths)/bin/claude"
exec nix develop "$worktree" --ignore-environment "${keep_args[@]}" \
  --command env "${env_overrides[@]+"${env_overrides[@]}"}" \
    "${deny_wrapper[@]}" "$claude_bin" "${claude_args[@]+"${claude_args[@]}"}"
