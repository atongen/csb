#!/usr/bin/env bash
#
# csb (claude sandbox)
#
# Runs Claude Code, sandboxed, in a per-branch git worktree.
#
#   csb [BRANCH]            ensure a worktree for BRANCH (off current HEAD) and
#                           launch sandboxed claude with the worktree as cwd
#   csb -y [BRANCH]         ...with --dangerously-skip-permissions (allow-all)
#   csb --here              launch in the current dir, no worktree (quick ops)
#   csb -n [BRANCH]         prepare/reuse the worktree only; don't launch claude
#   csb --ns NAME [BRANCH]  override the claude namespace (default: the branch)
#   csb -E [BRANCH]         ephemeral (throwaway) config, no namespace
#   csb [BRANCH] -- ARGS    pass ARGS straight through to claude
#   csb -d BRANCH           remove the worktree for BRANCH AND its namespace config
#                           (the branch itself is NOT deleted)
#   csb                     list existing csb worktrees
#
# Namespaces partition the sandboxed claude's config (history/sessions/settings).
# By default the namespace IS the branch (flattened): `csb feature/foo` uses a
# persistent config under ~/.csb/claudes/feature-foo, reused on every later run
# for that branch. --ns NAME overrides the default; -E/--ephemeral opts out of a
# namespace entirely (throwaway config); --ns global uses the real host ~/.claude
# (csb never mutates it). In --here mode the branch is taken from the current
# HEAD (a detached HEAD is an error — pass --ns or -E).
#
# The sandboxed claude comes from csb's OWN flake (generic jail), so the repo
# needs no csb-specific flake — any git repo works. `--no-sandbox` instead runs
# claude inside the repo's own devShell (full toolchain, unjailed). tmux is
# managed by you, outside the sandbox — only claude is jailed.
#
# Env:
#   CSB_SELF   flake ref to csb itself (default: the network-local git remote
#              git+ssh://git@git.grandrew.com/atongen/csb.git). Override for a
#              local working tree, e.g. CSB_SELF=path:/path/to/csb

set -euo pipefail

PROG=$(basename "$0")

# csb supplies the claude binaries from its own flake (so repos stay decoupled).
# Default: the network-local remote. For local dev against a working tree,
# override: CSB_SELF=path:/path/to/csb csb ...
CSB_SELF="${CSB_SELF:-git+ssh://git@git.grandrew.com/atongen/csb.git}"

usage() {
  cat <<EOF
USAGE:
  $PROG [-y] [--ns NAME] [BRANCH] [-- CLAUDE_ARGS...]
                                            launch sandboxed claude in BRANCH's worktree
  $PROG --here [-y] [--ns NAME] [-- ARGS]   launch in the current dir (no worktree)
  $PROG -n BRANCH                           prepare BRANCH's worktree, don't launch
  $PROG -d BRANCH                           remove BRANCH's worktree (keeps the branch)
  $PROG                                     list csb worktrees

OPTIONS:
  -y, --yolo      pass --dangerously-skip-permissions to claude (allow-all)
      --here      no worktree: run the sandbox in the current directory (quick
                  ops). Operates on the live checkout, so less isolated. The
                  namespace comes from the current HEAD branch (detached = error).
  -N, --ns NAME   override the claude namespace (default: the branch, flattened).
                  Persistent, isolated config under ~/.csb/claudes/NAME.
                  --ns global uses the real host ~/.claude (csb never mutates it).
  -E, --ephemeral use a throwaway config with no namespace (not persisted).
                  Mutually exclusive with --ns.
  -n, --no-launch prepare/reuse the worktree (incl. .worktreeinclude) and exit;
                  prints the worktree path on stdout
      --no-sandbox  run claude unjailed, inside the repo's own devShell (full
                  toolchain; needs a flake.nix with devShells.default)
  -d, --delete    delete mode: remove BRANCH's worktree AND its namespace config
                  under ~/.csb/claudes (keeps the branch itself)
  -h, --help      show this help
EOF
}

die() { echo "$PROG: $*" >&2; exit 1; }

# --- git / worktree helpers ---------------------------------------------------

flatten_branch() { echo "${1//\//-}"; }

worktree_path() {
  local repo_root="$1" branch="$2"
  echo "$repo_root/.worktrees/$(flatten_branch "$branch")"
}

# In a linked worktree, --git-dir and --git-common-dir differ.
in_worktree() {
  local gd cd
  gd=$(git rev-parse --path-format=absolute --git-dir 2>/dev/null) || return 1
  cd=$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null) || return 1
  [[ "$gd" != "$cd" ]]
}

# Echo the registered worktree path for $branch, else nothing.
find_worktree() {
  local repo_root="$1" branch="$2"
  git -C "$repo_root" worktree list --porcelain 2>/dev/null | \
    awk -v want="branch refs/heads/$branch" '
      /^worktree / { wt = substr($0, 10) }
      $0 == want   { print wt; exit }
    '
}

branch_exists() {
  local repo_root="$1" branch="$2"
  git -C "$repo_root" show-ref --verify --quiet "refs/heads/$branch" || \
    git -C "$repo_root" show-ref --verify --quiet "refs/remotes/origin/$branch"
}

# Echo the worktree path, creating/reusing as needed. Branch is created off the
# current HEAD if it doesn't already exist.
ensure_worktree() {
  local repo_root="$1" branch="$2" existing path
  existing=$(find_worktree "$repo_root" "$branch")
  if [[ -n "$existing" ]]; then
    # Reuse only a real csb worktree under .worktrees/. If the branch is checked
    # out elsewhere (commonly the main tree, when you're already on it), git
    # won't allow a second checkout — fail with guidance instead of returning
    # the wrong path.
    case "$existing" in
      "$repo_root"/.worktrees/*)
        echo "$existing"
        return 0
        ;;
      *)
        echo "$PROG: branch '$branch' is already checked out at: $existing" >&2
        echo "  a branch can live in only one worktree. Switch to your base branch" >&2
        echo "  (e.g. main) — or pick a different name — then: $PROG $branch" >&2
        return 1
        ;;
    esac
  fi
  path=$(worktree_path "$repo_root" "$branch")
  if branch_exists "$repo_root" "$branch"; then
    git -C "$repo_root" worktree add "$path" "$branch" >&2
  else
    git -C "$repo_root" worktree add -b "$branch" "$path" >&2
  fi
  echo "$path"
}

# Copy gitignored files matching <repo>/.worktreeinclude into a fresh worktree.
# Only files that match a pattern AND are gitignored are copied; existing files
# in the worktree are never overwritten. No-op if .worktreeinclude is missing.
process_worktreeinclude() {
  local repo_root="$1" wt_path="$2"
  local include_file="$repo_root/.worktreeinclude"
  [[ -f "$include_file" ]] || return 0

  local count=0 f src dest
  while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    git -C "$repo_root" check-ignore -q -- "$f" || continue
    src="$repo_root/$f"
    [[ -e "$src" ]] || continue
    dest="$wt_path/$f"
    [[ -e "$dest" ]] && continue
    mkdir -p "$(dirname "$dest")"
    cp -p "$src" "$dest"
    count=$((count + 1))
  done < <(git -C "$repo_root" ls-files --others -i --exclude-from="$include_file")

  if (( count > 0 )); then
    echo "$PROG: copied $count file(s) into worktree per .worktreeinclude" >&2
  fi
}

# The sandbox auths via a forwarded token (the jail's $HOME is ephemeral, so the
# host's ~/.claude is not used). Warn if nothing is exported to forward.
warn_if_no_token() {
  if [[ -z "${CLAUDE_CODE_OAUTH_TOKEN:-}" && -z "${ANTHROPIC_API_KEY:-}" ]]; then
    echo "$PROG: warning: neither CLAUDE_CODE_OAUTH_TOKEN nor ANTHROPIC_API_KEY is set;" >&2
    echo "  sandboxed claude won't be able to log in (no Keychain in the jail)." >&2
    echo "  Generate a token once with 'claude setup-token' and export it." >&2
  fi
}

CSB_NS_ROOT="$HOME/.csb/claudes"

# Resolve the effective claude namespace and export CSB_CLAUDE_CONFIG_DIR for the
# sandbox (empty = ephemeral / global). Precedence:
#   -E/--ephemeral          -> throwaway config (no namespace)
#   --ns global  (explicit) -> the real host ~/.claude (a separate variant)
#   --ns NAME    (explicit) -> persistent ~/.csb/claudes/NAME
#   default                 -> persistent ~/.csb/claudes/<branch> (flattened)
# There is no sticky state: the default is derived from the branch every run, so
# `csb BRANCH` is deterministic without remembering anything. The 'global'
# special-case is honored ONLY from an explicit --ns, never from a derived name,
# so a branch literally named "global" gets a plain dir, not your real config.
setup_namespace() {
  local worktree="$1" ns ns_dir cur_branch

  if [[ "$ephemeral" == "true" ]]; then
    sandbox_attr="claude-sandboxed"
    export CSB_CLAUDE_CONFIG_DIR=""
    echo "$PROG: namespace: ephemeral  (throwaway config)" >&2
    return
  fi

  # global: bind the real host ~/.claude via a separate variant that runs claude
  # directly (csb never seeds/mutates the real config). Explicit --ns only.
  if [[ "$namespace" == "global" ]]; then
    sandbox_attr="claude-sandboxed-global"
    export CSB_CLAUDE_CONFIG_DIR=""
    echo "$PROG: namespace: global  (real host ~/.claude — not modified by csb)" >&2
    return
  fi

  if [[ -n "$namespace" ]]; then
    ns="$namespace"
  elif [[ "$here" == "true" ]]; then
    # --here has no BRANCH arg: derive from the current HEAD branch. Fail fast
    # and loud on a detached HEAD rather than guessing.
    cur_branch=$(git -C "$worktree" branch --show-current 2>/dev/null || true)
    [[ -n "$cur_branch" ]] || die "--here on a detached HEAD: no branch to derive a namespace from.
  Pass --ns NAME or -E/--ephemeral explicitly."
    ns=$(flatten_branch "$cur_branch")
  else
    ns=$(flatten_branch "$branch")
  fi

  sandbox_attr="claude-sandboxed"
  mkdir -p "$CSB_NS_ROOT"   # the fixed bind target must exist before launch
  ns_dir="$CSB_NS_ROOT/$ns"
  mkdir -p "$ns_dir"
  export CSB_CLAUDE_CONFIG_DIR="$ns_dir"
  echo "$PROG: namespace: $ns  (persistent: $ns_dir)" >&2
}

# --- argument parsing ---------------------------------------------------------

mode="launch"
yolo="false"
no_sandbox="false"
no_launch="false"
here="false"
namespace=""
ephemeral="false"
sandbox_attr="claude-sandboxed"
branch=""
claude_args=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) usage; exit 0 ;;
    -d|--delete) mode="delete"; shift ;;
    -y|--yolo) yolo="true"; shift ;;
    -n|--no-launch) no_launch="true"; shift ;;
    --here) here="true"; shift ;;
    -N|--ns) [[ $# -ge 2 ]] || die "--ns requires a NAME"; namespace="$2"; shift 2 ;;
    -E|--ephemeral) ephemeral="true"; shift ;;
    --no-sandbox) no_sandbox="true"; shift ;;
    --) shift; claude_args+=("$@"); break ;;
    -*) usage >&2; die "unknown option: $1" ;;
    *)
      if [[ -z "$branch" ]]; then
        branch="$1"; shift
      else
        die "unexpected argument: $1"
      fi
      ;;
  esac
done

# --ns and -E are mutually exclusive: one names a namespace, the other opts out.
if [[ -n "$namespace" && "$ephemeral" == "true" ]]; then
  die "--ns and -E/--ephemeral are mutually exclusive"
fi

# Validate the namespace name: named namespaces become a directory under
# ~/.csb/claudes; 'global' is special (real host ~/.claude, no namespace dir).
if [[ -n "$namespace" ]]; then
  [[ "$namespace" =~ ^[A-Za-z0-9._-]+$ && "$namespace" != "." && "$namespace" != ".." ]] \
    || die "invalid namespace '$namespace' (use letters, digits, . _ -)"
fi

if [[ "$yolo" == "true" ]]; then
  claude_args=("--dangerously-skip-permissions" "${claude_args[@]+"${claude_args[@]}"}")
fi

# --- locate repo --------------------------------------------------------------

git rev-parse --git-dir >/dev/null 2>&1 || die "not in a git repository"
repo_root=$(git rev-parse --show-toplevel)

# --- list mode (no branch, launch, not --here) --------------------------------

if [[ "$mode" == "launch" && -z "$branch" && "$here" != "true" ]]; then
  echo "csb worktrees under $repo_root/.worktrees:"
  if ! git -C "$repo_root" worktree list 2>/dev/null \
      | awk -v pre="$repo_root/.worktrees/" 'index($1, pre) == 1'; then
    true
  fi
  exit 0
fi

# The worktree flow operates from the main checkout; --here intentionally runs
# in the current dir (which may itself be a worktree), so skip the guard there.
if [[ "$here" != "true" ]] && in_worktree; then
  die "refusing to operate from inside a worktree: $repo_root
  run $PROG from the main checkout instead"
fi

# --- delete mode --------------------------------------------------------------

if [[ "$mode" == "delete" ]]; then
  [[ -n "$branch" ]] || die "delete mode requires a branch name"
  wt_path=$(find_worktree "$repo_root" "$branch")
  if [[ -z "$wt_path" ]]; then
    candidate=$(worktree_path "$repo_root" "$branch")
    [[ -d "$candidate" ]] && wt_path="$candidate"
  fi
  if [[ -z "$wt_path" ]]; then
    echo "$PROG: no worktree for '$branch'"
  elif [[ -d "$wt_path" ]]; then
    echo "$PROG: removing worktree $wt_path"
    if ! git -C "$repo_root" worktree remove "$wt_path"; then
      echo "$PROG: worktree remove failed (uncommitted or untracked files?)" >&2
      echo "  to force: git -C $repo_root worktree remove --force $wt_path" >&2
      exit 1
    fi
  else
    echo "$PROG: pruning stale worktree registration for '$branch'"
    git -C "$repo_root" worktree prune
  fi

  # Also remove the persistent namespace config for this branch. Leaving stale
  # per-branch configs (session history + the auth they were seeded with) around
  # is a footprint/credential risk. Skip when an override makes removal unsafe or
  # irrelevant: -E (no namespace) or --ns global (the real ~/.claude).
  if [[ "$ephemeral" != "true" ]]; then
    if [[ "$namespace" == "global" ]]; then
      echo "$PROG: namespace 'global' is the real ~/.claude — not removing" >&2
    else
      ns_name="${namespace:-$(flatten_branch "$branch")}"
      ns_dir="$CSB_NS_ROOT/$ns_name"
      if [[ -d "$ns_dir" ]]; then
        echo "$PROG: removing namespace config $ns_dir"
        rm -rf "$ns_dir"
      fi
    fi
  fi
  exit 0
fi

# --- launch mode --------------------------------------------------------------

if [[ "$here" == "true" ]]; then
  # No worktree: run the sandbox in the current directory (quick/lightweight
  # ops). cwd is the live checkout, so it's less isolated than a worktree.
  worktree="$PWD"
else
  [[ -n "$branch" ]] || die "branch name required"
  worktree=$(ensure_worktree "$repo_root" "$branch") || exit 1
  process_worktreeinclude "$repo_root" "$worktree"
fi
setup_namespace "$worktree"

if [[ "$no_launch" == "true" ]]; then
  if [[ "$here" == "true" ]]; then
    echo "$PROG: --no-launch: nothing to prepare for --here" >&2
  else
    echo "$PROG: prepared worktree (not launching claude)" >&2
  fi
  echo "$worktree"
  exit 0
fi

cd "$worktree"

# --- unsandboxed: run a nix claude inside the repo's OWN devShell ------------
# Full toolchain + the repo's shellHook env; works where host claude isn't on
# PATH (e.g. a pure devShell). The repo flake is consumed as-is — just its
# devShell — so the repo never imports csb.
if [[ "$no_sandbox" == "true" ]]; then
  [[ -f "$worktree/flake.nix" ]] || die "--no-sandbox runs claude in the repo's devShell, but no flake.nix at $worktree"
  echo "$PROG: WARNING launching UNSANDBOXED claude in the devShell at $worktree" >&2
  # Apply the namespace to the unjailed claude directly (no jail wrapper to
  # translate CSB_CLAUDE_CONFIG_DIR). Empty (ephemeral/global) -> real ~/.claude.
  [[ -n "${CSB_CLAUDE_CONFIG_DIR:-}" ]] && export CLAUDE_CONFIG_DIR="$CSB_CLAUDE_CONFIG_DIR"
  claude_bin="$(nix build "${CSB_SELF}#claude" --no-link --print-out-paths)/bin/claude"
  exec nix develop "$worktree" --command "$claude_bin" "${claude_args[@]+"${claude_args[@]}"}"
fi

# --- sandboxed: csb's own generic jail (decoupled from the repo flake) -------
warn_if_no_token

# Provide git identity to the jail via env (the sandbox forwards GIT_AUTHOR_*/
# GIT_COMMITTER_*), so claude can commit. Derived from the host's effective
# git config; left unset if not configured.
git_name=$(git -C "$repo_root" config user.name 2>/dev/null || true)
git_email=$(git -C "$repo_root" config user.email 2>/dev/null || true)
if [[ -n "$git_name" ]]; then export GIT_AUTHOR_NAME="$git_name" GIT_COMMITTER_NAME="$git_name"; fi
if [[ -n "$git_email" ]]; then export GIT_AUTHOR_EMAIL="$git_email" GIT_COMMITTER_EMAIL="$git_email"; fi

echo "$PROG: launching sandboxed claude in $worktree" >&2

exec nix run "${CSB_SELF}#${sandbox_attr}" -- "${claude_args[@]+"${claude_args[@]}"}"
