(version 1)
(allow default)
(deny file* (subpath "<HOME>/.csb/claudes"))
(deny file-read* (subpath "<HOME>"))
(deny file-read* (subpath "<HOME>/hidden"))
(allow file-read* (subpath "<REPO>"))
(allow file-read* (subpath "<REPO>/.git"))
(allow file-read* (subpath "<TMP>"))
(allow file-read* (subpath "/private/tmp"))
(allow file-read* (subpath "<VARTMP>"))
(allow file-read* (subpath "/dev"))
(allow file-read* (subpath "<NS>"))
(allow file* (subpath "<NS>"))
(allow file-read-metadata (literal "<NSKEY>"))
(allow file-read-metadata (literal "<HOME>/.csb/claudes"))
(allow file-read-metadata (literal "<HOME>/.csb"))
(allow file-read-metadata (literal "<HOME>"))
(deny file-write*)
(allow file-write* (subpath "<REPO>"))
(allow file-write* (subpath "<REPO>/.git"))
(allow file-write* (subpath "<TMP>"))
(allow file-write* (subpath "/private/tmp"))
(allow file-write* (subpath "<VARTMP>"))
(allow file-write* (subpath "/dev"))
(allow file-write* (subpath "<NS>"))
(deny file-write* (subpath "<REPO>/.git/hooks"))
(deny file-write* (literal "<REPO>/.git/config"))
(deny file-write* (literal "<REPO>/.git/config.worktree"))
